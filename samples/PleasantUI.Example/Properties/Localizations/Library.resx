    <data name="BreadcrumbBar/Description" xml:space="preserve">
        <value>BreadcrumbBar displays the direct path of pages or folders to the current location. Items that overflow the available width are collapsed into an ellipsis flyout.</value>
    </data>
    <data name="BreadcrumbBar/BasicTitle" xml:space="preserve">
        <value>Basic usage</value>
    </data>
    <data name="BreadcrumbBar/BasicDesc" xml:space="preserve">
        <value>Declare BreadcrumbBarItem children directly. Click any item to raise the ItemClicked event.</value>
    </data>
    <data name="BreadcrumbBar/LastClicked" xml:space="preserve">
        <value>Last clicked:</value>
    </data>
    <data name="BreadcrumbBar/ItemsSourceTitle" xml:space="preserve">
        <value>Bound to ItemsSource</value>
    </data>
    <data name="BreadcrumbBar/ItemsSourceDesc" xml:space="preserve">
        <value>Bind an ObservableCollection to ItemsSource. Use Push / Pop / Reset to modify the path at runtime.</value>
    </data>
    <data name="BreadcrumbBar/Push" xml:space="preserve">
        <value>Push</value>
    </data>
    <data name="BreadcrumbBar/Pop" xml:space="preserve">
        <value>Pop</value>
    </data>
    <data name="BreadcrumbBar/Reset" xml:space="preserve">
        <value>Reset</value>
    </data>
    <data name="BreadcrumbBar/OverflowTitle" xml:space="preserve">
        <value>Overflow / ellipsis</value>
    </data>
    <data name="BreadcrumbBar/OverflowDesc" xml:space="preserve">
        <value>When items exceed the available width the control automatically collapses hidden items into an ellipsis button. Click it to see the flyout.</value>
    </data>
    <data name="BreadcrumbBar/ClickableLastTitle" xml:space="preserve">
        <value>Clickable last item</value>
    </data>
    <data name="BreadcrumbBar/ClickableLastDesc" xml:space="preserve">
        <value>Set IsLastItemClickEnabled="True" to make the current (last) item interactive instead of rendering it as plain text.</value>
    </data>
    <data name="BreadcrumbBar/PropertiesTitle" xml:space="preserve">
        <value>Key properties</value>
    </data>
    <data name="BreadcrumbBar/Prop/ItemsSource" xml:space="preserve">
        <value>Bound collection used as the data source for the breadcrumb trail.</value>
    </data>
    <data name="BreadcrumbBar/Prop/ItemTemplate" xml:space="preserve">
        <value>DataTemplate applied to each item when using ItemsSource.</value>
    </data>
    <data name="BreadcrumbBar/Prop/IsLastItemClickEnabled" xml:space="preserve">
        <value>When true the last item is rendered as a clickable button instead of plain text.</value>
    </data>
    <data name="BreadcrumbBar/Prop/ItemClicked" xml:space="preserve">
        <value>Raised when any item is clicked. Args expose Index (zero-based) and Item (the data object).</value>
