    <data name="CardTitle/CommandBar" xml:space="preserve">
        <value>CommandBar</value>
    </data>
    <data name="Card/CommandBar" xml:space="preserve">
        <value>A toolbar with primary commands inline and overflow in a popup menu.</value>
    </data>
    <data name="CommandBar/Description" xml:space="preserve">
        <value>CommandBar displays primary commands inline and moves overflow items into a popup. Supports dynamic overflow, label positions, toggle buttons, and separators.</value>
    </data>
    <data name="CommandBar/BasicTitle" xml:space="preserve">
        <value>Basic usage</value>
    </data>
    <data name="CommandBar/BasicDesc" xml:space="preserve">
        <value>Click the … button to open the overflow popup. Secondary commands always appear there. Click any button to see the action below.</value>
    </data>
    <data name="CommandBar/LabelBottomTitle" xml:space="preserve">
        <value>Labels below icon (always open)</value>
    </data>
    <data name="CommandBar/LabelBottomDesc" xml:space="preserve">
        <value>Set IsOpen="True" and IsSticky="True" to keep the bar permanently expanded so labels are always visible below each icon.</value>
    </data>
    <data name="CommandBar/LabelRightTitle" xml:space="preserve">
        <value>Labels on the right</value>
    </data>
    <data name="CommandBar/LabelRightDesc" xml:space="preserve">
        <value>Set DefaultLabelPosition="Right" to show labels beside the icon at all times.</value>
    </data>
    <data name="CommandBar/DisplayModeTitle" xml:space="preserve">
        <value>Closed display modes</value>
    </data>
    <data name="CommandBar/DisplayModeDesc" xml:space="preserve">
        <value>ClosedDisplayMode controls what is visible when the bar is closed: Compact shows icons, Minimal shows only the … button.</value>
    </data>
    <data name="CommandBar/OverflowTitle" xml:space="preserve">
        <value>Dynamic overflow</value>
    </data>
    <data name="CommandBar/OverflowDesc" xml:space="preserve">
        <value>When IsDynamicOverflowEnabled is true, primary commands automatically move to the overflow popup when there is not enough space.</value>
    </data>
    <data name="CommandBar/ToggleTitle" xml:space="preserve">
        <value>Toggle buttons</value>
    </data>
    <data name="CommandBar/ToggleDesc" xml:space="preserve">
        <value>CommandBarToggleButton supports checked/unchecked states with accent styling. The state is reflected below.</value>
    </data>
