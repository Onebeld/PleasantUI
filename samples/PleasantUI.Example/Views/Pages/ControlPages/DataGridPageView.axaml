<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controlPages="clr-namespace:PleasantUI.Example.ViewModels.Pages.ControlPages"
             xmlns:models="clr-namespace:PleasantUI.Example.Models"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="PleasantUI.Example.Views.Pages.ControlPages.DataGridPageView"
             x:DataType="controlPages:DataGridViewModel">
    <UserControl.DataContext>
        <controlPages:DataGridViewModel />
    </UserControl.DataContext>

    <Grid RowDefinitions="Auto,*" Margin="16 8 16 16">

        <!-- Toolbar -->
        <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0 0 0 12">
            <CheckBox Content="{Localize GridLines, Context=DataGrid}"
                      IsChecked="{CompiledBinding ShowGridLines}"
                      Margin="0 0 16 4" />
            <CheckBox Content="{Localize ReorderColumns, Context=DataGrid}"
                      IsChecked="{CompiledBinding CanUserReorderColumns}"
                      Margin="0 0 16 4" />
            <CheckBox Content="{Localize ResizeColumns, Context=DataGrid}"
                      IsChecked="{CompiledBinding CanUserResizeColumns}"
                      Margin="0 0 16 4" />
            <CheckBox Content="{Localize SortColumns, Context=DataGrid}"
                      IsChecked="{CompiledBinding CanUserSortColumns}"
                      Margin="0 0 16 4" />
            <CheckBox Content="{Localize RowDetails, Context=DataGrid}"
                      IsChecked="{CompiledBinding ShowRowDetails}"
                      Margin="0 0 0 4" />
        </WrapPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="1"
                  x:Name="MainDataGrid"
                  ItemsSource="{CompiledBinding DataModels}"
                  AutoGenerateColumns="False"
                  CanUserReorderColumns="{CompiledBinding CanUserReorderColumns}"
                  CanUserResizeColumns="{CompiledBinding CanUserResizeColumns}"
                  CanUserSortColumns="{CompiledBinding CanUserSortColumns}"
                  SelectionMode="Extended"
                  IsReadOnly="False">

            <DataGrid.RowDetailsTemplate>
                <DataTemplate x:DataType="models:DataModel">
                    <Border Padding="16 8" Background="{DynamicResource ControlFillColor1}">
                        <StackPanel Orientation="Horizontal" Spacing="24">
                            <StackPanel>
                                <TextBlock Text="{Localize DetailDepartment, Context=DataGrid}"
                                           FontSize="11" Foreground="{DynamicResource TextFillColor2}" />
                                <TextBlock Text="{CompiledBinding Department}" FontSize="14" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{Localize DetailSalary, Context=DataGrid}"
                                           FontSize="11" Foreground="{DynamicResource TextFillColor2}" />
                                <TextBlock Text="{CompiledBinding Salary, StringFormat=\{0:C0\}}" FontSize="14" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{Localize DetailStatus, Context=DataGrid}"
                                           FontSize="11" Foreground="{DynamicResource TextFillColor2}" />
                                <TextBlock Text="{CompiledBinding Status}" FontSize="14" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </DataGrid.RowDetailsTemplate>

            <DataGrid.Columns>
                <DataGridTextColumn Header="{Localize ColName, Context=DataGrid}"
                                    Binding="{CompiledBinding Name}"
                                    Width="*"
                                    IsReadOnly="False" />
                <DataGridTextColumn Header="{Localize ColDepartment, Context=DataGrid}"
                                    Binding="{CompiledBinding Department}"
                                    Width="*" />
                <DataGridTextColumn Header="{Localize ColAge, Context=DataGrid}"
                                    Binding="{CompiledBinding Age}"
                                    Width="80" />
                <DataGridTextColumn Header="{Localize ColSalary, Context=DataGrid}"
                                    Binding="{CompiledBinding Salary, StringFormat=\{0:C0\}}"
                                    Width="110" />
                <DataGridCheckBoxColumn Header="{Localize ColNew, Context=DataGrid}"
                                        Binding="{CompiledBinding IsNew}"
                                        Width="60" />
                <DataGridTextColumn Header="{Localize ColStatus, Context=DataGrid}"
                                    Binding="{CompiledBinding Status}"
                                    Width="100" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
