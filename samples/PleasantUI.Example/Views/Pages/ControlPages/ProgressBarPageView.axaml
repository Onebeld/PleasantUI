<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="PleasantUI.Example.Views.Pages.ControlPages.ProgressBarPageView">
    <StackPanel Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center" Width="360">
        <TextBlock Theme="{StaticResource BodyStrongTextBlockTheme}" Text="Determinate" />
        <ProgressBar Minimum="0" Maximum="100" Value="65" />

        <TextBlock Theme="{StaticResource BodyStrongTextBlockTheme}" Text="Indeterminate" />
        <ProgressBar IsIndeterminate="True" />

        <TextBlock Theme="{StaticResource BodyStrongTextBlockTheme}" Text="Disabled" />
        <ProgressBar Minimum="0" Maximum="100" Value="40" IsEnabled="False" />

        <TextBlock Theme="{StaticResource BodyStrongTextBlockTheme}" Text="ProgressRing (indeterminate)" />
        <ProgressRing IsIndeterminate="True" Width="48" Height="48" HorizontalAlignment="Left" />

        <TextBlock Theme="{StaticResource BodyStrongTextBlockTheme}" Text="ProgressRing (determinate)" />
        <ProgressRing Minimum="0" Maximum="100" Value="70" Width="48" Height="48" HorizontalAlignment="Left" />
    </StackPanel>
</UserControl>
