<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="PleasantUI.Example.Views.Pages.ControlPages.ProgressBarPageView">
    <StackPanel Spacing="12" Margin="0 8">

        <!-- Live animated demo -->
        <Border Background="{DynamicResource ControlFillColor1}"
                CornerRadius="{StaticResource ControlCornerRadius}"
                Padding="16">
            <StackPanel Spacing="12">
                <TextBlock Theme="{StaticResource BodyStrongTextBlockTheme}" Text="Live demo" />

                <Grid ColumnDefinitions="*,16,64" RowDefinitions="Auto,6,Auto,12,Auto">
                    <!-- Bar -->
                    <ProgressBar Grid.Row="0" Grid.Column="0"
                                 x:Name="LiveBar"
                                 Minimum="0" Maximum="100" Value="0"
                                 Height="8" />
                    <!-- Ring -->
                    <ProgressRing Grid.Row="0" Grid.RowSpan="5" Grid.Column="2"
                                  x:Name="LiveRing"
                                  Minimum="0" Maximum="100" Value="0"
                                  Width="64" Height="64" />
                    <!-- Percentage label -->
                    <TextBlock Grid.Row="2" Grid.Column="0"
                               x:Name="LiveLabel"
                               Foreground="{DynamicResource TextFillColor2}"
                               FontSize="12" Text="0 / 100" />
                    <!-- Buttons -->
                    <StackPanel Grid.Row="4" Grid.Column="0"
                                Orientation="Horizontal" Spacing="8">
                        <Button x:Name="StartButton" Content="Start"
                                Theme="{StaticResource AccentButtonTheme}" />
                        <Button x:Name="ResetButton" Content="Reset" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Indeterminate -->
        <Border Background="{DynamicResource ControlFillColor1}"
                CornerRadius="{StaticResource ControlCornerRadius}"
                Padding="16">
            <StackPanel Spacing="12">
                <TextBlock Theme="{StaticResource BodyStrongTextBlockTheme}" Text="Indeterminate" />
                <TextBlock Foreground="{DynamicResource TextFillColor2}" FontSize="12"
                           Text="Used when duration is unknown — both bar and ring variants." />
                <Grid ColumnDefinitions="*,16,Auto" VerticalAlignment="Center">
                    <ProgressBar Grid.Column="0" IsIndeterminate="True" Height="8" />
                    <ProgressRing Grid.Column="2" IsIndeterminate="True" Width="40" Height="40" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- Determinate states -->
        <Border Background="{DynamicResource ControlFillColor1}"
                CornerRadius="{StaticResource ControlCornerRadius}"
                Padding="16">
            <StackPanel Spacing="10">
                <TextBlock Theme="{StaticResource BodyStrongTextBlockTheme}" Text="Determinate states" />
                <TextBlock Foreground="{DynamicResource TextFillColor2}" FontSize="12" Text="25%" />
                <ProgressBar Minimum="0" Maximum="100" Value="25" Height="8" />
                <TextBlock Foreground="{DynamicResource TextFillColor2}" FontSize="12" Text="65%" />
                <ProgressBar Minimum="0" Maximum="100" Value="65" Height="8" />
                <TextBlock Foreground="{DynamicResource TextFillColor2}" FontSize="12" Text="Disabled (40%)" />
                <ProgressBar Minimum="0" Maximum="100" Value="40" Height="8" IsEnabled="False" />
            </StackPanel>
        </Border>

        <!-- Ring sizes -->
        <Border Background="{DynamicResource ControlFillColor1}"
                CornerRadius="{StaticResource ControlCornerRadius}"
                Padding="16">
            <StackPanel Spacing="12">
                <TextBlock Theme="{StaticResource BodyStrongTextBlockTheme}" Text="ProgressRing sizes" />
                <StackPanel Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
                    <StackPanel Spacing="6" HorizontalAlignment="Center">
                        <ProgressRing IsIndeterminate="True" Width="24" Height="24" HorizontalAlignment="Center" />
                        <TextBlock Text="24" FontSize="11" Foreground="{DynamicResource TextFillColor2}" HorizontalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Spacing="6" HorizontalAlignment="Center">
                        <ProgressRing IsIndeterminate="True" Width="40" Height="40" HorizontalAlignment="Center" />
                        <TextBlock Text="40" FontSize="11" Foreground="{DynamicResource TextFillColor2}" HorizontalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Spacing="6" HorizontalAlignment="Center">
                        <ProgressRing IsIndeterminate="True" Width="56" Height="56" HorizontalAlignment="Center" />
                        <TextBlock Text="56" FontSize="11" Foreground="{DynamicResource TextFillColor2}" HorizontalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Spacing="6" HorizontalAlignment="Center">
                        <ProgressRing IsIndeterminate="True" Width="72" Height="72" HorizontalAlignment="Center" />
                        <TextBlock Text="72" FontSize="11" Foreground="{DynamicResource TextFillColor2}" HorizontalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>
