<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="PleasantUI.Example.Views.Pages.ControlPages.CarouselPageView">
    <StackPanel Spacing="12" HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Theme="{StaticResource BodyStrongTextBlockTheme}" Text="Carousel" HorizontalAlignment="Center" />

        <Carousel x:Name="DemoCarousel" Width="400" Height="200">
            <Border Background="{DynamicResource AccentColor}" CornerRadius="{StaticResource ControlCornerRadius}">
                <TextBlock Text="Slide 1" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="White" />
            </Border>
            <Border Background="{DynamicResource ControlFillColor2}" CornerRadius="{StaticResource ControlCornerRadius}">
                <TextBlock Text="Slide 2" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <Border Background="{DynamicResource ControlFillColor3}" CornerRadius="{StaticResource ControlCornerRadius}">
                <TextBlock Text="Slide 3" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
        </Carousel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
            <Button x:Name="PrevButton" Content="← Previous" />
            <Button x:Name="NextButton" Content="Next →" />
        </StackPanel>
    </StackPanel>
</UserControl>
