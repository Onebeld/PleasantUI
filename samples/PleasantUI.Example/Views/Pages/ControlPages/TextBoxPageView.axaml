<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="PleasantUI.Example.Views.Pages.ControlPages.TextBoxPageView">
    <StackPanel Spacing="12" HorizontalAlignment="Center" VerticalAlignment="Center" Width="340">
        <TextBlock Theme="{StaticResource BodyStrongTextBlockTheme}" Text="{Localize TextBox}" />
        <TextBox Watermark="{Localize EnterText}" />
        <TextBlock Theme="{StaticResource BodyStrongTextBlockTheme}" Text="{Localize Password}" />
        <TextBox Watermark="{Localize EnterPassword}" PasswordChar="●" />
        <TextBlock Theme="{StaticResource BodyStrongTextBlockTheme}" Text="{Localize Multiline}" />
        <TextBox Watermark="{Localize EnterMultipleLines}" AcceptsReturn="True" TextWrapping="Wrap" Height="80" />
        <TextBlock Theme="{StaticResource BodyStrongTextBlockTheme}" Text="{Localize ReadOnly}" />
        <TextBox Text="{Localize ReadOnlyText}" IsReadOnly="True" />
        <TextBlock Theme="{StaticResource BodyStrongTextBlockTheme}" Text="{Localize Disabled}" />
        <TextBox Watermark="{Localize DisabledInput}" IsEnabled="False" />
        <TextBlock Theme="{StaticResource BodyStrongTextBlockTheme}" Text="{Localize NumericUpDown}" />
        <NumericUpDown Minimum="0" Maximum="100" Value="42" />
    </StackPanel>
</UserControl>
