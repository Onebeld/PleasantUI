<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="PleasantUI.Example.Views.Pages.ControlPages.TextBoxPageView">
    <StackPanel Spacing="12" HorizontalAlignment="Center" VerticalAlignment="Center" Width="340">
        <TextBlock Theme="{StaticResource BodyStrongTextBlockTheme}" Text="TextBox" />
        <TextBox Watermark="Enter text..." />

        <TextBlock Theme="{StaticResource BodyStrongTextBlockTheme}" Text="Password" />
        <TextBox Watermark="Enter password..." PasswordChar="●" />

        <TextBlock Theme="{StaticResource BodyStrongTextBlockTheme}" Text="Multiline" />
        <TextBox Watermark="Enter multiple lines..." AcceptsReturn="True"
                 TextWrapping="Wrap" Height="80" />

        <TextBlock Theme="{StaticResource BodyStrongTextBlockTheme}" Text="Read-only" />
        <TextBox Text="This is read-only text" IsReadOnly="True" />

        <TextBlock Theme="{StaticResource BodyStrongTextBlockTheme}" Text="Disabled" />
        <TextBox Watermark="Disabled input" IsEnabled="False" />

        <TextBlock Theme="{StaticResource BodyStrongTextBlockTheme}" Text="NumericUpDown" />
        <NumericUpDown Minimum="0" Maximum="100" Value="42" />
    </StackPanel>
</UserControl>
