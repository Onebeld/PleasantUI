<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:docking="using:PleasantUI.Controls.Docking"
             xmlns:local="using:PleasantUI.Example.Views.Pages.ToolkitPages"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="PleasantUI.Example.Views.Pages.ToolkitPages.DockingPageView">

    <Grid RowDefinitions="Auto,*">

        <!-- Description strip -->
        <Border Grid.Row="0"
                Padding="16 10"
                Background="{DynamicResource ControlFillColor1}"
                BorderBrush="{DynamicResource ControlBorderColor}"
                BorderThickness="0 0 0 1">
            <TextBlock Text="{Localize Docking/Description}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextFillColor2}" />
        </Border>

        <!-- Live docking demo -->
        <docking:ReDockHost Grid.Row="1"
                            x:Name="Host">

            <docking:ReDockHost.LeftSideBar>
                <docking:SideBar x:Name="LeftBar" Location="Left">
                    <docking:SideBar.ItemTemplate>
                        <DataTemplate x:DataType="local:ToolItem">
                            <docking:SideBarButton IsChecked="{Binding IsVisible, Mode=TwoWay}"
                                                   ToolTip.Tip="{Binding Label}">
                                <PathIcon Data="{Binding IconData}"
                                          Width="16" Height="16" />
                            </docking:SideBarButton>
                        </DataTemplate>
                    </docking:SideBar.ItemTemplate>
                </docking:SideBar>
            </docking:ReDockHost.LeftSideBar>

            <docking:ReDockHost.RightSideBar>
                <docking:SideBar x:Name="RightBar" Location="Right">
                    <docking:SideBar.ItemTemplate>
                        <DataTemplate x:DataType="local:ToolItem">
                            <docking:SideBarButton IsChecked="{Binding IsVisible, Mode=TwoWay}"
                                                   ToolTip.Tip="{Binding Label}">
                                <PathIcon Data="{Binding IconData}"
                                          Width="16" Height="16" />
                            </docking:SideBarButton>
                        </DataTemplate>
                    </docking:SideBar.ItemTemplate>
                </docking:SideBar>
            </docking:ReDockHost.RightSideBar>

            <docking:ReDockHost.MainContent>
                <docking:ReDock x:Name="MainDock">

                    <docking:ReDock.LeftContent>
                        <!-- Explorer panel — visible when Explorer button is checked -->
                        <Border x:Name="ExplorerPanel"
                                Background="{DynamicResource ControlFillColor1}"
                                BorderBrush="{DynamicResource ControlBorderColor}"
                                BorderThickness="0 0 1 0"
                                MinWidth="140">
                            <StackPanel Margin="10 8" Spacing="2">
                                <TextBlock Text="{Localize Docking/ExplorerPanel}"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           LetterSpacing="1"
                                           Foreground="{DynamicResource TextFillColor2}"
                                           Margin="0 0 0 6" />
                                <TextBlock Text="src/" FontSize="13" />
                                <TextBlock Text="Controls/" FontSize="13" Margin="12 0 0 0" Foreground="{DynamicResource TextFillColor2}" />
                                <TextBlock Text="Core/" FontSize="13" Margin="12 0 0 0" Foreground="{DynamicResource TextFillColor2}" />
                                <TextBlock Text="Styling/" FontSize="13" Margin="12 0 0 0" Foreground="{DynamicResource TextFillColor2}" />
                                <TextBlock Text="README.md" FontSize="13" />
                                <TextBlock Text="PleasantUI.sln" FontSize="13" />
                            </StackPanel>
                        </Border>
                    </docking:ReDock.LeftContent>

                    <!-- Center editor area -->
                    <Border Background="{DynamicResource BackgroundColor1}">
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Spacing="10">
                            <PathIcon Data="{StaticResource DocumentRegular}"
                                      Width="36" Height="36"
                                      Foreground="{DynamicResource TextFillColor3}" />
                            <TextBlock Text="{Localize Docking/EditorArea}"
                                       HorizontalAlignment="Center"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextFillColor2}" />
                            <TextBlock Text="{Localize Docking/DragHint}"
                                       HorizontalAlignment="Center"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextFillColor3}" />
                        </StackPanel>
                    </Border>

                    <docking:ReDock.RightContent>
                        <!-- Properties panel — visible when Properties button is checked -->
                        <Border x:Name="PropertiesPanel"
                                Background="{DynamicResource ControlFillColor1}"
                                BorderBrush="{DynamicResource ControlBorderColor}"
                                BorderThickness="1 0 0 0"
                                MinWidth="160">
                            <StackPanel Margin="10 8" Spacing="8">
                                <TextBlock Text="{Localize Docking/PropertiesPanel}"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           LetterSpacing="1"
                                           Foreground="{DynamicResource TextFillColor2}"
                                           Margin="0 0 0 2" />
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Localize Docking/PropName}" FontSize="11" Foreground="{DynamicResource TextFillColor2}" />
                                    <TextBlock Text="MyControl" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Localize Docking/PropWidth}" FontSize="11" Foreground="{DynamicResource TextFillColor2}" />
                                    <TextBlock Text="320" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Localize Docking/PropHeight}" FontSize="11" Foreground="{DynamicResource TextFillColor2}" />
                                    <TextBlock Text="240" FontWeight="SemiBold" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </docking:ReDock.RightContent>

                </docking:ReDock>
            </docking:ReDockHost.MainContent>

            <docking:ReDockHost.DockAreas>
                <docking:DockArea Location="LeftUpperTop"
                                  Target="LeftContent"
                                  LocalizedName="{Localize Docking/AreaLeftTop}"
                                  SideBar="{Binding #LeftBar}"
                                  View="{Binding #MainDock}" />
                <docking:DockArea Location="LeftLowerBottom"
                                  Target="RightContent"
                                  LocalizedName="{Localize Docking/AreaLeftBottom}"
                                  SideBar="{Binding #LeftBar}"
                                  View="{Binding #MainDock}" />
                <docking:DockArea Location="RightUpperTop"
                                  Target="RightContent"
                                  LocalizedName="{Localize Docking/AreaRightTop}"
                                  SideBar="{Binding #RightBar}"
                                  View="{Binding #MainDock}" />
                <docking:DockArea Location="RightLowerBottom"
                                  Target="LeftContent"
                                  LocalizedName="{Localize Docking/AreaRightBottom}"
                                  SideBar="{Binding #RightBar}"
                                  View="{Binding #MainDock}" />
            </docking:ReDockHost.DockAreas>

        </docking:ReDockHost>
    </Grid>

</UserControl>
