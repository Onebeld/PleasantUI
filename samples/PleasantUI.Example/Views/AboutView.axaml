<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:MaterialIcons="clr-namespace:PleasantUI.MaterialIcons;assembly=PleasantUI.MaterialIcons"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="PleasantUI.Example.Views.AboutView">
    <SmoothScrollViewer>
        <StackPanel Margin="25" Spacing="16">
            <!-- Header -->
            <TextBlock Text="{Localize AboutTitle}"
                       Margin="0 0 0 10"
                       Theme="{StaticResource TitleTextBlockTheme}" />

            <!-- Hero Section with Logo and Version -->
            <Border Background="{DynamicResource ControlFillColor1}"
                    CornerRadius="{StaticResource ControlCornerRadius}"
                    Padding="20">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <!-- Logo -->
                    <Border Grid.Column="0"
                            Background="#B2D3D3"
                            CornerRadius="{StaticResource ControlCornerRadius}"
                            Width="80"
                            Height="80">
                        <Viewbox Stretch="Uniform" Margin="10">
                            <Image Source="{StaticResource PleasantUI}" Width="64" Height="64" />
                        </Viewbox>
                    </Border>

                    <!-- Title and Version -->
                    <StackPanel Grid.Column="1" Margin="20 0" VerticalAlignment="Center">
                        <PathIcon Data="{StaticResource PleasantUINoLogo}"
                                  Height="35"
                                  Width="NaN"
                                  HorizontalAlignment="Left" />
                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0 8 0 0">
                            <TextBlock Foreground="{DynamicResource TextFillColor3}"
                                       FontSize="13"
                                       Text="{Localize About/License}" />
                            <TextBlock Foreground="{DynamicResource TextFillColor3}"
                                       FontSize="13"
                                       Text="|" />
                            <TextBlock x:Name="VersionTextBlock"
                                       FontSize="13"
                                       Foreground="{DynamicResource AccentTextFillColorPrimary}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Author -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <PathIcon Data="{StaticResource Onebeld}"
                                  Width="120"
                                  Height="NaN"
                                  HorizontalAlignment="Right" />
                        <TextBlock Text="Dmitry Zhutkov"
                                   FontSize="12"
                                   TextAlignment="Right"
                                   Foreground="{DynamicResource TextFillColor3}"
                                   Margin="0 5 0 0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Description Section with Rich Formatting -->
            <Border Background="{DynamicResource ControlFillColor2}"
                    CornerRadius="{StaticResource ControlCornerRadius}"
                    Padding="16">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Data="{StaticResource InformationCircleOutline}"
                                  Width="20"
                                  Height="20"
                                  Foreground="{DynamicResource AccentTextFillColorPrimary}" />
                        <TextBlock Text="{Localize Description}"
                                   FontWeight="SemiBold"
                                   FontSize="16" />
                    </StackPanel>

                    <!-- Multiline description in a styled read-only TextBox -->
                    <Border Background="{DynamicResource ControlFillColor1}"
                            CornerRadius="{StaticResource ControlCornerRadius}"
                            Padding="12">
                        <TextBox Text="{Localize LibraryDescription}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Padding="0"
                                 FontSize="14"
                                 LineHeight="22" />
                    </Border>

                    <!-- Feature Highlights -->
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto">
                        <Grid Grid.Column="0" Grid.Row="0" ColumnDefinitions="Auto,*" Margin="0 8" Classes="featureItem">
                            <PathIcon Grid.Column="0" Data="{StaticResource PaletteOutline}"
                                      Width="24"
                                      Height="24"
                                      Margin="0 2 10 0"
                                      Foreground="{DynamicResource AccentTextFillColorPrimary}" />
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="{Localize About/FeatureFluentDesign}"
                                           FontWeight="SemiBold"
                                           FontSize="13" />
                                <TextBlock Text="{Localize About/FeatureFluentDesignDesc}"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColor3}"
                                           FontSize="12" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Column="1" Grid.Row="0" ColumnDefinitions="Auto,*" Margin="8 0 0 8" Classes="featureItem">
                            <PathIcon Grid.Column="0" Data="{StaticResource ViewDashboardOutline}"
                                      Width="24"
                                      Height="24"
                                      Margin="0 2 10 0"
                                      Foreground="{DynamicResource AccentTextFillColorPrimary}" />
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="{Localize About/FeatureCustomControls}"
                                           FontWeight="SemiBold"
                                           FontSize="13" />
                                <TextBlock Text="{Localize About/FeatureCustomControlsDesc}"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColor3}"
                                           FontSize="12" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Column="0" Grid.Row="1" ColumnDefinitions="Auto,*" Margin="0 8" Classes="featureItem">
                            <PathIcon Grid.Column="0" Data="{StaticResource ThemeLightDark}"
                                      Width="24"
                                      Height="24"
                                      Margin="0 2 10 0"
                                      Foreground="{DynamicResource AccentTextFillColorPrimary}" />
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="{Localize About/FeatureThemes}"
                                           FontWeight="SemiBold"
                                           FontSize="13" />
                                <TextBlock Text="{Localize About/FeatureThemesDesc}"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColor3}"
                                           FontSize="12" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Column="1" Grid.Row="1" ColumnDefinitions="Auto,*" Margin="8 0 0 8" Classes="featureItem">
                            <PathIcon Grid.Column="0" Data="{StaticResource Translate}"
                                      Width="24"
                                      Height="24"
                                      Margin="0 2 10 0"
                                      Foreground="{DynamicResource AccentTextFillColorPrimary}" />
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="{Localize About/FeatureLocalization}"
                                           FontWeight="SemiBold"
                                           FontSize="13" />
                                <TextBlock Text="{Localize About/FeatureLocalizationDesc}"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColor3}"
                                           FontSize="12" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Column="0" Grid.Row="2" ColumnDefinitions="Auto,*" Margin="0 8" Classes="featureItem">
                            <PathIcon Grid.Column="0" Data="{StaticResource FastForward}"
                                      Width="24"
                                      Height="24"
                                      Margin="0 2 10 0"
                                      Foreground="{DynamicResource AccentTextFillColorPrimary}" />
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="{Localize About/FeatureAOT}"
                                           FontWeight="SemiBold"
                                           FontSize="13" />
                                <TextBlock Text="{Localize About/FeatureAOTDesc}"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColor3}"
                                           FontSize="12" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Column="1" Grid.Row="2" ColumnDefinitions="Auto,*" Margin="8 0 0 8" Classes="featureItem">
                            <PathIcon Grid.Column="0" Data="{StaticResource Laptop}"
                                      Width="24"
                                      Height="24"
                                      Margin="0 2 10 0"
                                      Foreground="{DynamicResource AccentTextFillColorPrimary}" />
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="{Localize About/FeatureCrossPlatform}"
                                           FontWeight="SemiBold"
                                           FontSize="13" />
                                <TextBlock Text="{Localize About/FeatureCrossPlatformDesc}"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColor3}"
                                           FontSize="12" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Links Section -->
            <OptionsDisplayItem Header="{Localize Links}"
                                Icon="{StaticResource LinkVariant}"
                                Expands="True"
                                IsExpanded="True">
                <OptionsDisplayItem.Content>
                    <StackPanel Spacing="10" Margin="45 0 0 0">
                        <Button x:Name="GitHubButton"
                                Theme="{StaticResource AppBarButtonTheme}"
                                HorizontalAlignment="Left"
                                Padding="12 6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource Github}"
                                          Width="18"
                                          Height="18" />
                                <TextBlock Text="{Localize About/GitHubRepo}"
                                           Foreground="{StaticResource AccentLightColor1}" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="PatreonButton"
                                Theme="{StaticResource AppBarButtonTheme}"
                                HorizontalAlignment="Left"
                                Padding="12 6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource HeartOutline}"
                                          Width="18"
                                          Height="18" />
                                <TextBlock Text="{Localize About/PatreonSupport}"
                                           Foreground="{StaticResource AccentLightColor1}" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="BoostyButton"
                                Theme="{StaticResource AppBarButtonTheme}"
                                HorizontalAlignment="Left"
                                Padding="12 6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource CurrencyUsd}"
                                          Width="18"
                                          Height="18" />
                                <TextBlock Text="{Localize About/BoostySupport}"
                                           Foreground="{StaticResource AccentLightColor1}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </OptionsDisplayItem.Content>
            </OptionsDisplayItem>

            <!-- Credits Section -->
            <Border Background="{DynamicResource ControlFillColor1}"
                    CornerRadius="{StaticResource ControlCornerRadius}"
                    Padding="16">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Data="{StaticResource Heart}"
                                  Width="18"
                                  Height="18"
                                  Foreground="{DynamicResource SystemErrorTextColor}" />
                        <TextBlock Text="{Localize About/CreditsTitle}"
                                   FontWeight="SemiBold"
                                   FontSize="14" />
                    </StackPanel>
                    <TextBox Text="{Localize About/CreditsText}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="0"
                             FontSize="13"
                             LineHeight="20"
                             Foreground="{DynamicResource TextFillColor3}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </SmoothScrollViewer>
</UserControl>
