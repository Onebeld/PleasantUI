<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:PleasantUI.Example.Views"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="PleasantUI.Example.MainView">
    <Panel>
        <NavigationView x:Name="MainNavigationView">

            <NavigationViewItem x:Name="HomeNavItem"
                                Header="{Localize Home}"
                                Icon="{x:Static MaterialIcons.HomeOutline}"
                                IsOpen="True"
                                SelectOnClose="True">
                <NavigationViewItem.Content>
                    <views:HomeView/>
                </NavigationViewItem.Content>

                <NavigationViewItem Header="{Localize BasicControls}"
                                    Icon="{x:Static MaterialIcons.ViewGridOutline}">
                    <NavigationViewItem Tag="Button"        Header="{Localize CardTitle/Button}"        Icon="{x:Static MaterialIcons.ButtonCursor}" />
                    <NavigationViewItem Tag="Checkbox"      Header="{Localize CardTitle/Checkbox}"      Icon="{x:Static MaterialIcons.CheckboxMarkedOutline}" />
                    <NavigationViewItem Tag="Progress"      Header="{Localize CardTitle/Progress}"      Icon="{x:Static MaterialIcons.ProgressHelper}" />
                    <NavigationViewItem Tag="Calendar"      Header="{Localize CardTitle/Calendar}"      Icon="{x:Static MaterialIcons.CalendarOutline}" />
                    <NavigationViewItem Tag="Carousel"      Header="{Localize CardTitle/Carousel}"      Icon="{x:Static MaterialIcons.ViewCarouselOutline}" />
                    <NavigationViewItem Tag="ComboBox"      Header="{Localize CardTitle/ComboBox}"      Icon="{x:Static MaterialIcons.ExpandAllOutline}" />
                    <NavigationViewItem Tag="TextBox"       Header="{Localize CardTitle/TextBox}"       Icon="{x:Static MaterialIcons.FormTextbox}" />
                    <NavigationViewItem Tag="DataGrid"      Header="{Localize CardTitle/DataGrid}"      Icon="{x:Static MaterialIcons.Grid}" />
                    <NavigationViewItem Tag="PinCode"       Header="{Localize CardTitle/PinCode}"       Icon="{x:Static MaterialIcons.KeyboardOutline}" />
                    <NavigationViewItem Tag="SelectionList" Header="{Localize CardTitle/SelectionList}" Icon="{x:Static MaterialIcons.ViewListOutline}" />
                </NavigationViewItem>

                <NavigationViewItem Header="{Localize PleasantControls}"
                                    Icon="{x:Static MaterialIcons.StarOutline}">
                    <NavigationViewItem Tag="PleasantSnackbar"   Header="{Localize CardTitle/PleasantSnackbar}"   Icon="{x:Static MaterialIcons.InformationOutline}" />
                    <NavigationViewItem Tag="InformationBlock"   Header="{Localize CardTitle/InformationBlock}"   Icon="{x:Static MaterialIcons.InformationBoxOutline}" />
                    <NavigationViewItem Tag="OptionsDisplayItem" Header="{Localize CardTitle/OptionsDisplayItem}" Icon="{x:Static MaterialIcons.ViewListOutline}" />
                    <NavigationViewItem Tag="PleasantTabView"    Header="{Localize CardTitle/PleasantTabView}"    Icon="{x:Static MaterialIcons.Tab}" />
                    <NavigationViewItem Tag="PleasantMenu"       Header="{Localize CardTitle/PleasantMenu}"       Icon="{x:Static MaterialIcons.MenuOpen}" />
                    <NavigationViewItem Tag="Timeline"           Header="{Localize CardTitle/Timeline}"           Icon="{x:Static MaterialIcons.TimelineOutline}" />
                    <NavigationViewItem Tag="InstallWizard"      Header="{Localize CardTitle/InstallWizard}"      Icon="{x:Static MaterialIcons.WizardHat}" />
                    <NavigationViewItem Tag="PleasantDrawer"     Header="{Localize CardTitle/PleasantDrawer}"     Icon="{x:Static MaterialIcons.DrawingBox}" />
                    <NavigationViewItem Tag="PopConfirm"         Header="{Localize CardTitle/PopConfirm}"         Icon="{x:Static MaterialIcons.CheckboxMarkedCircle}" />
                    <NavigationViewItem Tag="PathPicker"         Header="{Localize CardTitle/PathPicker}"         Icon="{x:Static MaterialIcons.FolderOpenOutline}" />
                    <NavigationViewItem Tag="PleasantMiniWindow" Header="{Localize CardTitle/PleasantMiniWindow}" Icon="{x:Static MaterialIcons.WindowMinimize}" />
                    <NavigationViewItem Tag="BreadcrumbBar"      Header="{Localize CardTitle/BreadcrumbBar}"      Icon="{x:Static MaterialIcons.PageNextOutline}" />
                    <NavigationViewItem Tag="CommandBar"         Header="{Localize CardTitle/CommandBar}"         Icon="{x:Static MaterialIcons.ViewGridOutline}" />
                    <NavigationViewItem Tag="DashboardCard"      Header="{Localize CardTitle/DashboardCard}"      Icon="{x:Static MaterialIcons.ViewDashboardOutline}" />
                    <NavigationViewItem Tag="LogViewerPanel"     Header="{Localize CardTitle/LogViewerPanel}"     Icon="{x:Static MaterialIcons.TextBoxOutline}" />
                    <NavigationViewItem Tag="TerminalPanel"      Header="{Localize CardTitle/TerminalPanel}"      Icon="{x:Static MaterialIcons.ConsoleLine}" />
                    <NavigationViewItem Tag="TreeViewPanel"      Header="{Localize CardTitle/TreeViewPanel}"      Icon="{x:Static MaterialIcons.FileTreeOutline}" />
                    <NavigationViewItem Tag="ItemListPanel"      Header="{Localize CardTitle/ItemListPanel}"      Icon="{x:Static MaterialIcons.FormatListBulletedType}" />
                    <NavigationViewItem Tag="PropertyGrid"       Header="{Localize CardTitle/PropertyGrid}"       Icon="{x:Static MaterialIcons.TableColumnPlusAfter}" />
                    <NavigationViewItem Tag="DownloadPanel"      Header="{Localize CardTitle/DownloadPanel}"      Icon="{x:Static MaterialIcons.DownloadOutline}" />
                    <NavigationViewItem Tag="CrashReportDialog"  Header="{Localize CardTitle/CrashReportDialog}"  Icon="{x:Static MaterialIcons.BugOutline}" />
                </NavigationViewItem>

                <NavigationViewItem Header="{Localize ToolKit}"
                                    Icon="{x:Static MaterialIcons.WrenchOutline}">
                    <NavigationViewItem Tag="MessageBox"  Header="{Localize CardTitle/MessageBox}"  Icon="{x:Static MaterialIcons.MessageOutline}" />
                    <NavigationViewItem Tag="NoticeDialog" Header="{Localize CardTitle/NoticeDialog}" Icon="{x:Static MaterialIcons.InformationOutline}" />
                    <NavigationViewItem Tag="StepDialog"  Header="{Localize CardTitle/StepDialog}"  Icon="{x:Static MaterialIcons.OrderNumericAscending}" />
                    <NavigationViewItem Tag="Docking"     Header="{Localize CardTitle/Docking}"     Icon="{x:Static MaterialIcons.ViewDashboardOutline}" />
                </NavigationViewItem>
            </NavigationViewItem>

            <NavigationViewItem x:Name="AboutNavItem"
                                Header="{Localize About}"
                                Icon="{x:Static MaterialIcons.InformationOutline}"
                                DockPanel.Dock="Bottom">
                <NavigationViewItem.Content>
                    <views:AboutView/>
                </NavigationViewItem.Content>
            </NavigationViewItem>

            <NavigationViewItem x:Name="SettingsNavItem"
                                Header="{Localize Settings}"
                                DockPanel.Dock="Bottom"
                                Icon="{x:Static MaterialIcons.CogOutline}"
                                Margin="0 0 0 5">
                <NavigationViewItem.Content>
                    <views:SettingsView/>
                </NavigationViewItem.Content>
            </NavigationViewItem>
        </NavigationView>

        <OnFormFactor>
            <OnFormFactor.Default>
                <Control />
            </OnFormFactor.Default>
            <OnFormFactor.Mobile>
                <StackPanel Spacing="5"
                            Margin="50 0"
                            Height="45"
                            Orientation="Horizontal"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Left"
                            IsHitTestVisible="False">
                    <Image Source="{DynamicResource PleasantUILogo}" Width="16" Height="16" VerticalAlignment="Center" />
                    <TextBlock Text="PleasantUI" VerticalAlignment="Center" />
                    <TextBlock Text="Example"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColor3}" />
                </StackPanel>
            </OnFormFactor.Mobile>
        </OnFormFactor>
    </Panel>
</UserControl>
