<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        VGUI example-app specific overrides.
        Loaded dynamically into Application.Current.Styles when VGUI theme is active,
        so these styles load AFTER App.axaml defaults and win via load order.
    -->

    <!-- Square card buttons -->
    <Style Selector="Button.card-button">
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <!-- Square card icon borders -->
    <Style Selector="Border.card-icon-border">
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="BorderThickness" Value="1 1 0 0" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlDarkFillColor1}" />
    </Style>

</Styles>
