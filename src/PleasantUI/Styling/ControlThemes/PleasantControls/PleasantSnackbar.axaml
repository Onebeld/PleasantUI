<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    x:ClassModifier="internal">
    <Design.PreviewWith>
        <Border Padding="20">
            <StackPanel Spacing="8">
                <PleasantSnackbar Content="Simple message" />
            </StackPanel>
        </Border>
    </Design.PreviewWith>

    <ControlTheme x:Key="{x:Type PleasantSnackbar}" TargetType="PleasantSnackbar">
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="MinWidth" Value="40" />
        <Setter Property="MaxWidth" Value="480" />
        <Setter Property="ClipToBounds" Value="False" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Opacity" Value="0" />
        <Setter Property="Margin" Value="20" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Bottom" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="ZIndex" Value="99" />

        <Setter Property="Template">
            <ControlTemplate>
                <ShadowBorder CornerRadius="99"
                              BlurRadius="5"
                              Offset="0 1"
                              ShadowColor="#3C000000">
                    <Border x:Name="PART_Snackbar"
                            Background="{DynamicResource BackgroundColor1}"
                            BorderBrush="{DynamicResource ControlBorderColor}"
                            BorderThickness="1"
                            CornerRadius="99">
                        <Border CornerRadius="99"
                                Margin="-1"
                                ClipToBounds="True">
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                                  VerticalAlignment="Center">

                                <!-- Severity icon pill -->
                                <Border x:Name="PART_IconBorder"
                                        Grid.Column="0"
                                        Background="{DynamicResource SystemFillColorNeutral}"
                                        Width="30"
                                        Height="30"
                                        CornerRadius="99"
                                        BorderBrush="{DynamicResource ControlBorderColor}"
                                        BorderThickness="1"
                                        Margin="5"
                                        VerticalAlignment="Center">
                                    <PathIcon Foreground="{CompiledBinding $parent.Background, Converter={x:Static OtherConverters.ForegroundFromColor}}"
                                              Data="{TemplateBinding Icon}" />
                                </Border>

                                <!-- Content area: title + message + action button -->
                                <Grid x:Name="PART_Grid"
                                      Grid.Column="1"
                                      RowDefinitions="Auto,Auto"
                                      ColumnDefinitions="*,Auto"
                                      Opacity="0"
                                      VerticalAlignment="Center"
                                      Margin="0 6 6 6">

                                    <!-- Title (only visible when :titled) -->
                                    <TextBlock x:Name="PART_Title"
                                               Grid.Row="0" Grid.Column="0"
                                               Text="{TemplateBinding Title}"
                                               FontWeight="SemiBold"
                                               FontSize="13"
                                               TextWrapping="NoWrap"
                                               IsVisible="False" />

                                    <!-- Message — spans both rows, centered when no title -->
                                    <ContentPresenter x:Name="PART_ContentPresenter"
                                                      Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                                                      Content="{TemplateBinding Content}"
                                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                                      VerticalContentAlignment="Center"
                                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      Margin="{TemplateBinding Padding}"
                                                      
                                                      TextAlignment="Start" />

                                    <!-- Action button (text button or custom control) -->
                                    <Button x:Name="PART_Button"
                                            Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                            Theme="{DynamicResource AppBarButtonTheme}"
                                            Foreground="{DynamicResource AccentLightColor3}"
                                            CornerRadius="99"
                                            VerticalAlignment="Center"
                                            Margin="5 5 0 5" />

                                    <!-- Custom action button slot -->
                                    <ContentPresenter x:Name="PART_ActionButton"
                                                      Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                                      Content="{TemplateBinding ActionButton}"
                                                      VerticalContentAlignment="Center"
                                                      IsVisible="{TemplateBinding ActionButton, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                      Margin="5 5 0 5" />
                                </Grid>

                                <!-- Close button (only visible when :closable) -->
                                <Button x:Name="PART_CloseButton"
                                        Grid.Column="2"
                                        Theme="{DynamicResource AppBarButtonTheme}"
                                        CornerRadius="99"
                                        Width="28" Height="28"
                                        Padding="6"
                                        VerticalAlignment="Center"
                                        Margin="0 0 6 0"
                                        IsVisible="False">
                                    <PathIcon Data="{StaticResource DismissRegular}"
                                              Width="10" Height="10" />
                                </Button>

                                <!-- Fixed right-edge spacer — always present -->
                                <Border Grid.Column="3" Width="10" />

                            </Grid>
                        </Border>
                    </Border>
                </ShadowBorder>
            </ControlTemplate>
        </Setter>

        <!-- ── Animations (unchanged) ──────────────────────────────────── -->
        <Style Selector="^">
            <Setter Property="OpenAnimation">
                <Animation Duration="0:0:0.2" FillMode="Both" Easing="0,0 0,1">
                    <KeyFrame KeyTime="0:0:0">
                        <Setter Property="ScaleTransform.ScaleX" Value="1.5" />
                        <Setter Property="ScaleTransform.ScaleY" Value="1.5" />
                        <Setter Property="Opacity" Value="0" />
                    </KeyFrame>
                    <KeyFrame KeyTime="0:0:0.2">
                        <Setter Property="ScaleTransform.ScaleX" Value="1" />
                        <Setter Property="ScaleTransform.ScaleY" Value="1" />
                        <Setter Property="Opacity" Value="1" />
                    </KeyFrame>
                </Animation>
            </Setter>
            <Setter Property="CloseAnimation">
                <Animation Duration="0:0:0.05" FillMode="Both">
                    <KeyFrame KeyTime="0:0:0">
                        <Setter Property="ScaleTransform.ScaleX" Value="1" />
                        <Setter Property="ScaleTransform.ScaleY" Value="1" />
                        <Setter Property="Opacity" Value="1" />
                    </KeyFrame>
                    <KeyFrame KeyTime="0:0:0.05">
                        <Setter Property="ScaleTransform.ScaleX" Value="1.1" />
                        <Setter Property="ScaleTransform.ScaleY" Value="1.1" />
                        <Setter Property="Opacity" Value="0" />
                    </KeyFrame>
                </Animation>
            </Setter>
        </Style>

        <!-- ── Severity icon colours (unchanged) ───────────────────────── -->
        <Style Selector="^ /template/ Border#PART_IconBorder">
            <Setter Property="Background" Value="{DynamicResource SystemFillColorNeutral}" />
        </Style>
        <Style Selector="^:information /template/ Border#PART_IconBorder">
            <Setter Property="Background" Value="{DynamicResource SystemFillColorNeutral}" />
        </Style>
        <Style Selector="^:success /template/ Border#PART_IconBorder">
            <Setter Property="Background" Value="{DynamicResource SystemFillColorSuccess}" />
        </Style>
        <Style Selector="^:warning /template/ Border#PART_IconBorder">
            <Setter Property="Background" Value="{DynamicResource SystemFillColorCaution}" />
        </Style>
        <Style Selector="^:error /template/ Border#PART_IconBorder">
            <Setter Property="Background" Value="{DynamicResource SystemFillColorCritical}" />
        </Style>

        <!-- ── Grid fade-in transition (unchanged) ─────────────────────── -->
        <Style Selector="^ /template/ Grid#PART_Grid">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.1" />
                </Transitions>
            </Setter>
        </Style>

        <!-- ── Title visible when :titled ──────────────────────────────── -->
        <Style Selector="^:titled /template/ TextBlock#PART_Title">
            <Setter Property="IsVisible" Value="True" />
        </Style>

        <!-- When titled: message moves to row 1, loses rowspan, top-aligned -->
        <Style Selector="^:titled /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="(Grid.Row)" Value="1" />
            <Setter Property="(Grid.RowSpan)" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
        </Style>

        <!-- ── Close button visible when :closable ─────────────────────── -->
        <Style Selector="^:closable /template/ Button#PART_CloseButton">
            <Setter Property="IsVisible" Value="True" />
        </Style>

    </ControlTheme>
</ResourceDictionary>
