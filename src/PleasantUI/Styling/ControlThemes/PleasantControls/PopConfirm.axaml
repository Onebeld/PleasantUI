<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:PleasantUI.Controls"
                    x:ClassModifier="internal">
    <Design.PreviewWith>
        <Border Padding="40">
            <controls:PopConfirm PopupHeader="Delete item?"
                                  PopupContent="This action cannot be undone.">
                <Button Content="Delete" />
            </controls:PopConfirm>
        </Border>
    </Design.PreviewWith>

    <ControlTheme x:Key="{x:Type controls:PopConfirm}" TargetType="controls:PopConfirm">
        <Setter Property="Placement" Value="BottomEdgeAlignedLeft" />

        <Setter Property="Template">
            <ControlTemplate>
                <Panel>
                    <!-- Wrapped trigger content -->
                    <ContentPresenter Name="PART_ContentPresenter"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}" />

                    <!-- Confirmation popup -->
                    <Popup Name="PART_Popup"
                           IsLightDismissEnabled="True"
                           IsOpen="{Binding IsDropdownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                           OverlayInputPassThroughElement="{Binding #PART_ContentPresenter}"
                           Placement="{TemplateBinding Placement}">
                        <ShadowBorder CornerRadius="{StaticResource ControlCornerRadius}"
                                      Margin="6 4 6 6"
                                      BlurRadius="5"
                                      ShadowColor="#3C000000"
                                      Offset="0 1">
                            <Border MaxWidth="320"
                                    Padding="16"
                                    Background="{DynamicResource BackgroundColor1}"
                                    BorderBrush="{DynamicResource ControlBorderColor}"
                                    BorderThickness="{StaticResource ControlBorderThickness}"
                                    CornerRadius="{StaticResource ControlCornerRadius}">
                                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*,Auto">

                                    <!-- Icon area -->
                                    <Panel Grid.Row="0" Grid.Column="0"
                                           Margin="0 2 10 0"
                                           VerticalAlignment="Top">
                                        <!-- Custom icon when provided -->
                                        <ContentPresenter Content="{TemplateBinding Icon}"
                                                          IsVisible="{TemplateBinding Icon, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                        <!-- Default warning icon when no custom icon -->
                                        <PathIcon Name="PART_DefaultIcon"
                                                  Width="16" Height="16"
                                                  Data="{StaticResource DeleteRegular}"
                                                  Foreground="{DynamicResource SystemFillColorCaution}"
                                                  IsVisible="{TemplateBinding Icon, Converter={x:Static ObjectConverters.IsNull}}" />
                                    </Panel>

                                    <!-- Header + body -->
                                    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="6">
                                        <ContentPresenter Content="{TemplateBinding PopupHeader}"
                                                          ContentTemplate="{TemplateBinding PopupHeaderTemplate}"
                                                          FontSize="14"
                                                          FontWeight="SemiBold"
                                                          TextWrapping="Wrap"
                                                          IsVisible="{TemplateBinding PopupHeader, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                          Foreground="{DynamicResource TextFillColor1}" />
                                        <ContentPresenter Content="{TemplateBinding PopupContent}"
                                                          ContentTemplate="{TemplateBinding PopupContentTemplate}"
                                                          FontSize="13"
                                                          TextWrapping="Wrap"
                                                          Foreground="{DynamicResource TextFillColor2}" />
                                    </StackPanel>

                                    <!-- Close button -->
                                    <Button Name="PART_CloseButton"
                                            Grid.Row="0" Grid.Column="2"
                                            Theme="{DynamicResource AppBarButtonTheme}"
                                            Width="24" Height="24"
                                            Padding="5"
                                            Margin="8 0 0 0"
                                            VerticalAlignment="Top">
                                        <PathIcon Data="{StaticResource DismissRegular}"
                                                  Width="9" Height="9" />
                                    </Button>

                                    <!-- Action buttons -->
                                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                                Margin="0 14 0 0"
                                                Spacing="8"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right">
                                        <Button Name="PART_CancelButton"
                                                Command="{TemplateBinding CancelCommand}"
                                                CommandParameter="{TemplateBinding CancelCommandParameter}"
                                                Content="{Localize PopConfirm/Cancel}" />
                                        <Button Name="PART_ConfirmButton"
                                                Theme="{DynamicResource AccentButtonTheme}"
                                                Command="{TemplateBinding ConfirmCommand}"
                                                CommandParameter="{TemplateBinding ConfirmCommandParameter}"
                                                Content="{Localize PopConfirm/Confirm}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </ShadowBorder>
                    </Popup>
                </Panel>
            </ControlTemplate>
        </Setter>

        <!-- Severity variants via style classes -->
        <Style Selector="^.Warning /template/ PathIcon#PART_DefaultIcon">
            <Setter Property="Data"       Value="{StaticResource DeleteRegular}" />
            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCaution}" />
        </Style>
        <Style Selector="^.Error /template/ PathIcon#PART_DefaultIcon">
            <Setter Property="Data"       Value="{StaticResource CloseCircleRegular}" />
            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCritical}" />
        </Style>
        <Style Selector="^.Success /template/ PathIcon#PART_DefaultIcon">
            <Setter Property="Data"       Value="{StaticResource CheckmarkRegular}" />
            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccess}" />
        </Style>
        <Style Selector="^.Information /template/ PathIcon#PART_DefaultIcon">
            <Setter Property="Data"       Value="{StaticResource MoreRegular}" />
            <Setter Property="Foreground" Value="{DynamicResource SystemFillColorNeutral}" />
        </Style>
        
        <!-- Animation -->
        <Style Selector="^[Placement=Bottom] /template/ Popup[IsOpen=True] > ShadowBorder,
                         ^[Placement=BottomEdgeAlignedLeft] /template/ Popup[IsOpen=True] > ShadowBorder,
                         ^[Placement=BottomEdgeAlignedRight] /template/ Popup[IsOpen=True] > ShadowBorder">
            <Style.Animations>
                <Animation Duration="0:0:0.2" FillMode="Forward" Easing="CubicEaseOut">
                    <KeyFrame Cue="0%">
                        <Setter Property="TranslateTransform.Y"
                                Value="-100" />
                        <Setter Property="Opacity" Value="0" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="TranslateTransform.Y" Value="0" />
                        <Setter Property="Opacity" Value="1" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="^[Placement=Top] /template/ Popup[IsOpen=True] > ShadowBorder,
                         ^[Placement=TopEdgeAlignedLeft] /template/ Popup[IsOpen=True] > ShadowBorder,
                         ^[Placement=TopEdgeAlignedRight] /template/ Popup[IsOpen=True] > ShadowBorder">
            <Style.Animations>
                <Animation Duration="0:0:0.2" FillMode="Forward" Easing="CubicEaseOut">
                    <KeyFrame Cue="0%">
                        <Setter Property="TranslateTransform.Y"
                                Value="100" />
                        <Setter Property="Opacity" Value="0" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="TranslateTransform.Y" Value="0" />
                        <Setter Property="Opacity" Value="1" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="^[Placement=Left] /template/ Popup[IsOpen=True] > ShadowBorder,
                         ^[Placement=LeftEdgeAlignedBottom] /template/ Popup[IsOpen=True] > ShadowBorder,
                         ^[Placement=LeftEdgeAlignedTop] /template/ Popup[IsOpen=True] > ShadowBorder">
            <Style.Animations>
                <Animation Duration="0:0:0.2" FillMode="Forward" Easing="CubicEaseOut">
                    <KeyFrame Cue="0%">
                        <Setter Property="TranslateTransform.X"
                                Value="100" />
                        <Setter Property="Opacity" Value="0" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="TranslateTransform.X" Value="0" />
                        <Setter Property="Opacity" Value="1" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="^[Placement=Right] /template/ Popup[IsOpen=True] > ShadowBorder,
                         ^[Placement=RightEdgeAlignedBottom] /template/ Popup[IsOpen=True] > ShadowBorder,
                         ^[Placement=RightEdgeAlignedTop] /template/ Popup[IsOpen=True] > ShadowBorder">
            <Style.Animations>
                <Animation Duration="0:0:0.2" FillMode="Forward" Easing="CubicEaseOut">
                    <KeyFrame Cue="0%">
                        <Setter Property="TranslateTransform.X"
                                Value="-100" />
                        <Setter Property="Opacity" Value="0" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="TranslateTransform.X" Value="0" />
                        <Setter Property="Opacity" Value="1" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </ControlTheme>
</ResourceDictionary>
