<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:PleasantUI.Controls"
                    x:ClassModifier="internal">

    <Design.PreviewWith>
        <Border Width="260" Height="500" Background="{DynamicResource BackgroundColor1}">
            <controls:TreeViewPanel FilterWatermark="Filter entities...">
                <controls:TreeViewSection Header="Queues"
                                          IsLoading="False">
                    <controls:TreeViewSection.SectionIcon>
                        <x:Static Member="controls:TreeViewPanel.SectionIcon" />
                    </controls:TreeViewSection.SectionIcon>
                </controls:TreeViewSection>
            </controls:TreeViewPanel>
        </Border>
    </Design.PreviewWith>

    <!-- ── TreeViewSection ───────────────────────────────────────────────── -->
    <ControlTheme x:Key="{x:Type controls:TreeViewSection}" TargetType="controls:TreeViewSection">
        <Setter Property="Background"      Value="Transparent" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />

        <Setter Property="Template">
            <ControlTemplate>
                <Expander IsExpanded="{TemplateBinding IsExpanded, Mode=TwoWay}"
                          HorizontalAlignment="Stretch"
                          Margin="4 2 4 0">

                    <!-- Section header -->
                    <Expander.Header>
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6">
                            <!-- Icon badge -->
                            <Border Grid.Column="0"
                                    Width="18" Height="18"
                                    CornerRadius="{DynamicResource ControlCornerRadius}"
                                    Background="{TemplateBinding IconBackground}"
                                    IsVisible="{TemplateBinding SectionIcon, Converter={x:Static ObjectConverters.IsNotNull}}">
                                <PathIcon Data="{TemplateBinding SectionIcon}"
                                          Width="10" Height="10"
                                          Foreground="{TemplateBinding IconForeground}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                            </Border>

                            <!-- Title -->
                            <TextBlock Grid.Column="1"
                                       Text="{TemplateBinding Header}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColor1}" />

                            <!-- Count badge -->
                            <Border Grid.Column="2"
                                    Background="{DynamicResource ControlFillColor2}"
                                    CornerRadius="{DynamicResource RoundedControlCornerRadius}"
                                    Padding="5 1"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{TemplateBinding ItemCount}"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColor2}" />
                            </Border>
                        </Grid>
                    </Expander.Header>

                    <!-- Section body -->
                    <StackPanel Spacing="0">
                        <!-- Loading indicator -->
                        <Border Name="PART_LoadingRow"
                                IsVisible="False"
                                Padding="4 4"
                                Margin="4 2">
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <ProgressBar IsIndeterminate="True" Width="48" Height="2" />
                                <TextBlock Text="{TemplateBinding LoadingText}"
                                           FontSize="10"
                                           Foreground="{DynamicResource TextFillColor2}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- Items list -->
                        <ListBox Name="PART_ItemsList"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 MaxHeight="{TemplateBinding MaxListHeight}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ItemTemplate="{TemplateBinding ItemTemplate}">
                            <ListBox.Styles>
                                <Style Selector="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding"    Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                </Style>
                            </ListBox.Styles>
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                        </ListBox>

                        <!-- Empty state -->
                        <Border Name="PART_EmptyRow"
                                IsVisible="False"
                                Padding="8 6">
                            <TextBlock Text="No items"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextFillColor3}"
                                       HorizontalAlignment="Center" />
                        </Border>
                    </StackPanel>
                </Expander>
            </ControlTemplate>
        </Setter>

        <Style Selector="^:loading /template/ Border#PART_LoadingRow">
            <Setter Property="IsVisible" Value="True" />
        </Style>
        <Style Selector="^:empty /template/ Border#PART_EmptyRow">
            <Setter Property="IsVisible" Value="True" />
        </Style>
    </ControlTheme>

    <!-- ── TreeViewPanel ─────────────────────────────────────────────────── -->
    <ControlTheme x:Key="{x:Type controls:TreeViewPanel}" TargetType="controls:TreeViewPanel">
        <Setter Property="Background"      Value="{DynamicResource BackgroundColor2}" />
        <Setter Property="BorderBrush"     Value="{DynamicResource ControlBorderColor}" />
        <Setter Property="BorderThickness" Value="{DynamicResource ControlBorderThickness}" />
        <Setter Property="CornerRadius"    Value="{DynamicResource ControlCornerRadius}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment"   Value="Stretch" />

        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        ClipToBounds="True">
                    <DockPanel>

                        <!-- ── Search / filter bar ─────────────────────── -->
                        <Border DockPanel.Dock="Top"
                                Background="{DynamicResource BackgroundColor3}"
                                BorderBrush="{DynamicResource ControlBorderColor}"
                                BorderThickness="0 0 0 1"
                                Padding="8 6">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                <Border Grid.Column="0"
                                        Background="{DynamicResource BackgroundColor1}"
                                        BorderBrush="{DynamicResource ControlBorderColor}"
                                        BorderThickness="{DynamicResource ControlBorderThickness}"
                                        CornerRadius="{DynamicResource ControlCornerRadius}">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <PathIcon Grid.Column="0"
                                                  Data="{DynamicResource SearchRegular}"
                                                  Width="12" Height="12"
                                                  Margin="8 0 4 0"
                                                  Foreground="{DynamicResource TextFillColor3}" />
                                        <TextBox Name="PART_SearchBox"
                                                 Grid.Column="1"
                                                 Watermark="{TemplateBinding FilterWatermark}"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Padding="4 5"
                                                 FontSize="12" />
                                        <Button Grid.Column="2"
                                                Theme="{DynamicResource AppBarButtonTheme}"
                                                Width="22" Height="22"
                                                Padding="4"
                                                Margin="0 0 2 0"
                                                IsVisible="{Binding FilterText, RelativeSource={RelativeSource TemplatedParent}, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                            <PathIcon Data="{DynamicResource DismissRegular}"
                                                      Width="8" Height="8" />
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- Collapse-all button -->
                                <Button Grid.Column="1"
                                        Theme="{DynamicResource AppBarButtonTheme}"
                                        Width="28" Height="28"
                                        Padding="6"
                                        ToolTip.Tip="Collapse all">
                                    <PathIcon Data="{DynamicResource ChevronUpRegular}"
                                              Width="10" Height="10" />
                                </Button>
                            </Grid>
                        </Border>

                        <!-- ── Sections ────────────────────────────────── -->
                        <SmoothScrollViewer HorizontalScrollBarVisibility="Disabled"
                                            VerticalScrollBarVisibility="Auto">
                            <ItemsControl Name="PART_SectionsHost"
                                          Margin="0 2 0 6">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Spacing="0" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </SmoothScrollViewer>
                    </DockPanel>
                </Border>
            </ControlTemplate>
        </Setter>
    </ControlTheme>

</ResourceDictionary>
