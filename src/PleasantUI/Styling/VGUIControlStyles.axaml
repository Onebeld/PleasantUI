<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:PleasantUI.Controls;assembly=PleasantUI">

    <!--
        VGUI Theme Application Styles.
        Loaded as a child of PleasantTheme (via Add/Remove on the Styles instance),
        so StaticResource lookups here can resolve keys from PleasantTheme.Resources
        (where VGUIControlThemes.axaml is merged).
    -->

    <!-- Shadow the named button themes so any button explicitly using them gets VGUI bevel -->
    <Styles.Resources>
        <ResourceDictionary>
            <ControlTheme x:Key="AccentButtonTheme" TargetType="Button" BasedOn="{StaticResource VGUIAccentButtonTheme}" />
            <ControlTheme x:Key="DangerButtonTheme" TargetType="Button" BasedOn="{StaticResource VGUIDangerButtonTheme}" />
            <ControlTheme x:Key="AppBarButtonTheme" TargetType="Button" BasedOn="{StaticResource VGUIAppBarButtonTheme}" />
            <ControlTheme x:Key="CloseButtonTheme" TargetType="Button" BasedOn="{StaticResource VGUICloseButtonTheme}" />
            <!-- Override ControlCornerRadius to 0 so any DynamicResource binding to it becomes square -->
            <CornerRadius x:Key="ControlCornerRadius">0</CornerRadius>
            <CornerRadius x:Key="RoundedControlCornerRadius">0</CornerRadius>        </ResourceDictionary>
    </Styles.Resources>

    <Style Selector="Button">
        <Setter Property="Theme" Value="{StaticResource VGUIButtonTheme}" />
    </Style>

    <Style Selector="CheckBox">
        <Setter Property="Theme" Value="{StaticResource VGUICheckBoxTheme}" />
    </Style>

    <Style Selector="RadioButton">
        <Setter Property="Theme" Value="{StaticResource VGUIRadioButtonTheme}" />
    </Style>

    <Style Selector="TextBox">
        <Setter Property="Theme" Value="{StaticResource VGUITextBoxTheme}" />
    </Style>

    <Style Selector="ComboBox">
        <Setter Property="Theme" Value="{StaticResource VGUIComboBoxTheme}" />
    </Style>

    <Style Selector="ComboBoxItem">
        <Setter Property="Theme" Value="{StaticResource VGUIComboBoxItemTheme}" />
    </Style>

    <Style Selector="NavigationViewItem">
        <Setter Property="Theme" Value="{StaticResource VGUINavigationViewItemTheme}" />
    </Style>

    <Style Selector="NavigationView">
        <Setter Property="Theme" Value="{StaticResource VGUINavigationViewTheme}" />
    </Style>

    <Style Selector="OptionsDisplayItem">
        <Setter Property="Theme" Value="{StaticResource VGUIOptionsDisplayItemTheme}" />
    </Style>

    <Style Selector="controls|SelectionListItem">
        <Setter Property="Theme" Value="{StaticResource VGUISelectionListItemTheme}" />
    </Style>

    <Style Selector="controls|SelectionList">
        <Setter Property="Theme" Value="{StaticResource VGUISelectionListTheme}" />
    </Style>

    <!-- VGUI PinCodeItem — inset bevel, square corners -->
    <Style Selector="PinCodeItem">
        <Setter Property="Theme" Value="{StaticResource VGUIPinCodeItemTheme}" />
    </Style>

    <!-- VGUI DatePicker — inset bevel, square corners, no shadow popup -->
    <Style Selector="DatePicker">
        <Setter Property="Theme" Value="{StaticResource VGUIDatePickerTheme}" />
    </Style>

    <Style Selector="controls|PleasantDatePicker">
        <Setter Property="Theme" Value="{StaticResource VGUIPleasantDatePickerTheme}" />
    </Style>

    <Style Selector="CalendarDatePicker">
        <Setter Property="Theme" Value="{StaticResource VGUICalendarDatePickerTheme}" />
    </Style>

    <!--
        VGUI Danger dialog header — replaces the flat red fill with a bevel-style
        raised panel using a vertical gradient (lighter top → darker bottom)
        plus a top highlight border and bottom shadow border.
        Applies to MessageBox (DangerHeader set via DynamicResource in XAML).
        PleasantDialog danger header is handled in code-behind (PleasantDialog.axaml.cs).
    -->
    <Style Selector="ContentDialog Border#DangerHeader">
        <Setter Property="BorderThickness" Value="0 2 0 2" />
        <Setter Property="BorderBrush" Value="#FF8B1A10" />
        <Setter Property="Padding" Value="20 12" />
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                    <GradientStop Color="#FFE84030" Offset="0" />
                    <GradientStop Color="#FFB72B1D" Offset="0.5" />
                    <GradientStop Color="#FF8B1A10" Offset="1" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        VGUI ControlPageCard — handled by VGUIExampleStyles.axaml loaded dynamically
        from App.axaml.cs when VGUI is active, so it loads after App.axaml defaults
        and correctly overrides the template's local CornerRadius values.
    -->

</Styles>
