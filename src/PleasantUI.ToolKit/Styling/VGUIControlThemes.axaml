<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:PleasantUI.ToolKit.Controls"
        xmlns:pleasant="clr-namespace:PleasantUI.Controls;assembly=PleasantUI">

    <Styles.Resources>
        <!-- Override ControlCornerRadius to 0 so any DynamicResource binding to it becomes square -->
        <CornerRadius x:Key="ControlCornerRadius">0</CornerRadius>
        <CornerRadius x:Key="RoundedControlCornerRadius">0</CornerRadius>
    </Styles.Resources>

    <!-- VGUI CrashReportDialog — square corners -->
    <Style Selector="controls|CrashReportDialog">
        <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="controls|CrashReportDialog /template/ pleasant|ShadowBorder">
        <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="controls|CrashReportDialog /template/ Border">
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <!-- VGUI StepDialog — square corners -->
    <Style Selector="controls|StepDialog">
        <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="controls|StepDialog /template/ pleasant|ShadowBorder">
        <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="controls|StepDialog /template/ Border">
        <Setter Property="CornerRadius" Value="0" />
    </Style>

</Styles>
