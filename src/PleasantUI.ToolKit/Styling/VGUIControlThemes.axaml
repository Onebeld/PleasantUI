<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:PleasantUI.ToolKit.Controls">

    <!-- VGUI CrashReportDialog Theme - square corners -->
    <ControlTheme x:Key="{x:Type controls:CrashReportDialog}" TargetType="controls:CrashReportDialog" BasedOn="{StaticResource {x:Type controls:CrashReportDialog}}">
        <!-- Override all corner radius bindings to 0 -->
        <Style Selector="^ /template/ ShadowBorder">
            <Setter Property="CornerRadius" Value="0" />
        </Style>
        <Style Selector="^ /template/ Border">
            <Setter Property="CornerRadius" Value="0" />
        </Style>
        <!-- Icon badge -->
        <Style Selector="^ /template/ Border#PART_BevelOuter">
            <Setter Property="CornerRadius" Value="0" />
        </Style>
        <!-- Tab items -->
        <Style Selector="^ /template/ ListBoxItem">
            <Setter Property="CornerRadius" Value="0" />
        </Style>
        <!-- Status row -->
        <Style Selector="^ /template/ Border#PART_StatusRow">
            <Setter Property="CornerRadius" Value="0" />
        </Style>
    </ControlTheme>

    <!-- VGUI StepDialog Theme - square corners -->
    <ControlTheme x:Key="{x:Type controls:StepDialog}" TargetType="controls:StepDialog" BasedOn="{StaticResource {x:Type controls:StepDialog}}">
        <!-- Override all corner radius bindings to 0 -->
        <Style Selector="^ /template/ ShadowBorder">
            <Setter Property="CornerRadius" Value="0" />
        </Style>
        <Style Selector="^ /template/ Border">
            <Setter Property="CornerRadius" Value="0" />
        </Style>
        <!-- Status row -->
        <Style Selector="^ /template/ Border#PART_StatusRow">
            <Setter Property="CornerRadius" Value="0" />
        </Style>
        <!-- Step item badge -->
        <Style Selector="^ /template/ ItemsControl > controls:StepItem /template/ Border">
            <Setter Property="CornerRadius" Value="0" />
        </Style>
    </ControlTheme>

</ResourceDictionary>
