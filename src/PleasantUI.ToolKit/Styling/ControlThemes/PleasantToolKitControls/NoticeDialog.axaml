<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:PleasantUI.ToolKit.Controls"
                    x:ClassModifier="internal">

    <Design.PreviewWith>
        <Border Width="500" Height="400" Background="#40000000">
            <controls:NoticeDialog Title="Under Construction"
                                   Message="This version of the System is in active development. Please note that the user interface, features, and components will continue to be improved throughout the development cycle."
                                   FooterText="- Development Team"
                                   PrimaryButtonText="OK"
                                   Severity="WorkInProgress" />
        </Border>
    </Design.PreviewWith>

    <!-- ── Severity color brushes ───────────────────────────────────────────── -->
    
    <!-- Info (Blue) -->
    <SolidColorBrush x:Key="NoticeDialogInfoBrush" Color="{DynamicResource SystemFillColorInfo}" />
    <SolidColorBrush x:Key="NoticeDialogInfoBackgroundBrush" Color="{DynamicResource SystemFillColorInfoBackground}" />
    
    <!-- Warning (Yellow/Orange) -->
    <SolidColorBrush x:Key="NoticeDialogWarningBrush" Color="{DynamicResource SystemFillColorCaution}" />
    <SolidColorBrush x:Key="NoticeDialogWarningBackgroundBrush" Color="{DynamicResource SystemFillColorCautionBackground}" />
    
    <!-- Error (Red) -->
    <SolidColorBrush x:Key="NoticeDialogErrorBrush" Color="{DynamicResource SystemFillColorCritical}" />
    <SolidColorBrush x:Key="NoticeDialogErrorBackgroundBrush" Color="{DynamicResource SystemFillColorCriticalBackground}" />
    
    <!-- Success (Green) -->
    <SolidColorBrush x:Key="NoticeDialogSuccessBrush" Color="{DynamicResource SystemFillColorSuccess}" />
    <SolidColorBrush x:Key="NoticeDialogSuccessBackgroundBrush" Color="{DynamicResource SystemFillColorSuccessBackground}" />
    
    <!-- Work In Progress (Yellow/Gold) -->
    <SolidColorBrush x:Key="NoticeDialogWipBrush" Color="{DynamicResource SystemFillColorAttention}" />
    <SolidColorBrush x:Key="NoticeDialogWipBackgroundBrush" Color="{DynamicResource SystemFillColorAttentionBackground}" />

    <!-- ── Severity icon data ──────────────────────────────────────────────────── -->
    
    <PathGeometry x:Key="InfoIconGeometry">M11 2a9 9 0 1 0 0 18 9 9 0 0 0 0-18zm0 16a7 7 0 1 1 0-14 7 7 0 0 1 0 14zm1-11h-2v2h2V7zm0 4h-2v4h2v-4z</PathGeometry>
    <PathGeometry x:Key="WarningIconGeometry">M12 2L1 21h22L12 2zm0 3.99L19.53 19H4.47L12 5.99zM11 10v4h2v-4h-2zm0 6v2h2v-2h-2z</PathGeometry>
    <PathGeometry x:Key="ErrorIconGeometry">M12 2C6.47 2 2 6.47 2 12s4.47 10 10 10 10-4.47 10-10S17.53 2 12 2zm5 13.59L15.59 17 12 13.41 8.41 17 7 15.59 10.59 12 7 8.41 8.41 7 12 10.59 15.59 7 17 8.41 13.41 12 17 15.59z</PathGeometry>
    <PathGeometry x:Key="SuccessIconGeometry">M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z</PathGeometry>
    <PathGeometry x:Key="WipIconGeometry">M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z</PathGeometry>

    <!-- ── NoticeDialog ──────────────────────────────────────────────────────── -->
    <ControlTheme x:Key="{x:Type controls:NoticeDialog}" TargetType="controls:NoticeDialog">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Opacity" Value="0" />
        <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="CubicEaseOut" />
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2" Easing="CubicEaseOut" />
            </Transitions>
        </Setter>

        <Setter Property="RenderTransform">
            <ScaleTransform ScaleX="0.95" ScaleY="0.95" CenterX="0.5" CenterY="0.5" />
        </Setter>

        <Setter Property="Template">
            <ControlTemplate>
                <ShadowBorder CornerRadius="{TemplateBinding CornerRadius}"
                              BlurRadius="40"
                              ShadowColor="#5A000000"
                              Offset="0 8">
                    <Border Background="{DynamicResource BackgroundColor1}"
                            BorderBrush="{DynamicResource ControlBorderColor}"
                            BorderThickness="{DynamicResource ControlBorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            MinWidth="{TemplateBinding MinDialogWidth}"
                            MinHeight="{TemplateBinding MinDialogHeight}"
                            ClipToBounds="True">
                        <Grid RowDefinitions="Auto,*,Auto">

                            <!-- ── Header (severity icon + title) ──────────────────────── -->
                            <Border Grid.Row="0"
                                    Name="HeaderBorder"
                                    Padding="{DynamicResource PleasantDialogHeaderPadding}"
                                    Background="{DynamicResource NoticeDialogInfoBackgroundBrush}">
                                <Grid ColumnDefinitions="Auto,*">
                                    <PathIcon Grid.Column="0"
                                              Name="SeverityIcon"
                                              Width="{DynamicResource PleasantDialogIconSize}"
                                              Height="{DynamicResource PleasantDialogIconSize}"
                                              Margin="{DynamicResource PleasantDialogIconMargin}"
                                              Data="{DynamicResource InfoIconGeometry}"
                                              Foreground="{DynamicResource NoticeDialogInfoBrush}"
                                              VerticalAlignment="Center" />
                                    
                                    <TextBlock Grid.Column="1"
                                               Name="TitleText"
                                               Text="{TemplateBinding Title}"
                                               Theme="{DynamicResource SubtitleTextBlockTheme}"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>

                            <!-- ── Message body ───────────────────────────────────────── -->
                            <SmoothScrollViewer Grid.Row="1"
                                                Margin="0 8 0 0"
                                                HorizontalScrollBarVisibility="Disabled"
                                                VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="{DynamicResource PleasantDialogContentPadding}" Spacing="12">
                                    <TextBlock Text="{TemplateBinding Message}"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextFillColor1}"
                                               FontSize="14" />
                                </StackPanel>
                            </SmoothScrollViewer>

                            <!-- ── Footer text ───────────────────────────────────────── -->
                            <Border Grid.Row="2"
                                    Name="FooterBorder"
                                    Padding="{DynamicResource PleasantDialogContentPadding}"
                                    BorderBrush="{DynamicResource ControlBorderColor}"
                                    BorderThickness="0 1 0 0"
                                    Background="{DynamicResource BackgroundColor3}"
                                    IsVisible="False">
                                <TextBlock Text="{TemplateBinding FooterText}"
                                           Foreground="{DynamicResource TextFillColor2}"
                                           FontSize="12"
                                           FontStyle="Italic"
                                           HorizontalAlignment="Left" />
                            </Border>

                            <!-- ── Action buttons ─────────────────────────────────────── -->
                            <Border Grid.Row="2"
                                    BorderBrush="{DynamicResource ControlBorderColor}"
                                    BorderThickness="0 1 0 0"
                                    Background="{DynamicResource BackgroundColor3}"
                                    Padding="16 12"
                                    Margin="{Binding ElementName=FooterBorder, Path=IsVisible, Converter={x:Static ObjectConverters.Convert}, ConverterParameter='0,1,0,0:0,0,0,0'}">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8"
                                            HorizontalAlignment="Right">
                                    <Button Name="PART_SecondaryButton"
                                            Content="{TemplateBinding SecondaryButtonText}"
                                            IsVisible="False" />
                                    <Button Name="PART_PrimaryButton"
                                            Content="{TemplateBinding PrimaryButtonText}"
                                            Theme="{DynamicResource AccentButtonTheme}"
                                            IsVisible="False" />
                                </StackPanel>
                            </Border>

                        </Grid>
                    </Border>
                </ShadowBorder>
            </ControlTemplate>
        </Setter>

        <!-- ── Severity-based styling ───────────────────────────────────────────── -->

        <!-- Info severity -->
        <Style Selector="^ /template/ Border#HeaderBorder">
            <Setter Property="Background" Value="{DynamicResource NoticeDialogInfoBackgroundBrush}" />
        </Style>
        <Style Selector="^ /template/ PathIcon#SeverityIcon">
            <Setter Property="Data" Value="{DynamicResource InfoIconGeometry}" />
            <Setter Property="Foreground" Value="{DynamicResource NoticeDialogInfoBrush}" />
        </Style>

        <!-- Warning severity -->
        <Style Selector="^[Severity=Warning] /template/ Border#HeaderBorder">
            <Setter Property="Background" Value="{DynamicResource NoticeDialogWarningBackgroundBrush}" />
        </Style>
        <Style Selector="^[Severity=Warning] /template/ PathIcon#SeverityIcon">
            <Setter Property="Data" Value="{DynamicResource WarningIconGeometry}" />
            <Setter Property="Foreground" Value="{DynamicResource NoticeDialogWarningBrush}" />
        </Style>

        <!-- Error severity -->
        <Style Selector="^[Severity=Error] /template/ Border#HeaderBorder">
            <Setter Property="Background" Value="{DynamicResource NoticeDialogErrorBackgroundBrush}" />
        </Style>
        <Style Selector="^[Severity=Error] /template/ PathIcon#SeverityIcon">
            <Setter Property="Data" Value="{DynamicResource ErrorIconGeometry}" />
            <Setter Property="Foreground" Value="{DynamicResource NoticeDialogErrorBrush}" />
        </Style>

        <!-- Success severity -->
        <Style Selector="^[Severity=Success] /template/ Border#HeaderBorder">
            <Setter Property="Background" Value="{DynamicResource NoticeDialogSuccessBackgroundBrush}" />
        </Style>
        <Style Selector="^[Severity=Success] /template/ PathIcon#SeverityIcon">
            <Setter Property="Data" Value="{DynamicResource SuccessIconGeometry}" />
            <Setter Property="Foreground" Value="{DynamicResource NoticeDialogSuccessBrush}" />
        </Style>

        <!-- Work In Progress severity -->
        <Style Selector="^[Severity=WorkInProgress] /template/ Border#HeaderBorder">
            <Setter Property="Background" Value="{DynamicResource NoticeDialogWipBackgroundBrush}" />
        </Style>
        <Style Selector="^[Severity=WorkInProgress] /template/ PathIcon#SeverityIcon">
            <Setter Property="Data" Value="{DynamicResource WipIconGeometry}" />
            <Setter Property="Foreground" Value="{DynamicResource NoticeDialogWipBrush}" />
        </Style>

        <!-- ── Visibility pseudo-classes ─────────────────────────────────────────── -->

        <!-- Secondary button -->
        <Style Selector="^:hasSecondary /template/ Button#PART_SecondaryButton">
            <Setter Property="IsVisible" Value="True" />
        </Style>

        <!-- Primary button -->
        <Style Selector="^:hasSecondary=false /template/ Button#PART_PrimaryButton">
            <Setter Property="IsVisible" Value="True" />
        </Style>

        <!-- Footer text -->
        <Style Selector="^:hasFooter /template/ Border#FooterBorder">
            <Setter Property="IsVisible" Value="True" />
        </Style>

        <!-- ── Open state animation ───────────────────────────────────────────────── -->
        <Style Selector="^:open">
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="^:open">
            <Setter Property="RenderTransform">
                <ScaleTransform ScaleX="1" ScaleY="1" CenterX="0.5" CenterY="0.5" />
            </Setter>
        </Style>

    </ControlTheme>

</ResourceDictionary>
