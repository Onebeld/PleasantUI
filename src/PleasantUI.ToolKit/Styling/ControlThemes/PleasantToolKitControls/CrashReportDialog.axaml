<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:PleasantUI.ToolKit.Controls"
                    x:ClassModifier="internal">

    <Design.PreviewWith>
        <Border Width="640" Height="560" Background="#40000000">
            <controls:CrashReportDialog ApplicationName="MyApp"
                                        ApplicationVersion="1.0.0"
                                        ExceptionType="System.NullReferenceException"
                                        ExceptionMessage="Object reference not set to an instance of an object."
                                        ExceptionSource="MyApp.Core"
                                        StackTrace="   at MyApp.Core.Foo() in Foo.cs:line 42"
                                        OccurredAt="2025-04-09 14:32:01" />
        </Border>
    </Design.PreviewWith>

    <!-- ── Tab strip item ────────────────────────────────────────────────── -->
    <ControlTheme x:Key="CrashReportTabItemTheme" TargetType="ListBoxItem">
        <Setter Property="Background"   Value="Transparent" />
        <Setter Property="Foreground"   Value="{DynamicResource TextFillColor2}" />
        <Setter Property="Padding"      Value="14 7" />
        <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
        <Setter Property="Cursor"       Value="Hand" />
        <Setter Property="FontSize"     Value="12" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.1" />
            </Transitions>
        </Setter>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center"
                                      TextBlock.FontSize="{TemplateBinding FontSize}"
                                      TextBlock.Foreground="{TemplateBinding Foreground}" />
                </Border>
            </ControlTemplate>
        </Setter>
        <Style Selector="^:pointerover">
            <Setter Property="Background" Value="{DynamicResource ControlFillColor1}" />
        </Style>
        <Style Selector="^:selected">
            <Setter Property="Background" Value="{DynamicResource ControlFillColor2}" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColor1}" />
        </Style>
    </ControlTheme>

    <!-- ── CrashReportDialog ─────────────────────────────────────────────── -->
    <ControlTheme x:Key="{x:Type controls:CrashReportDialog}" TargetType="controls:CrashReportDialog">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment"   Value="Center" />
        <Setter Property="Opacity"             Value="0" />
        <Setter Property="MinWidth"            Value="560" />
        <Setter Property="MaxWidth"            Value="680" />

        <Setter Property="OpenAnimation">
            <Animation Duration="0:0:0.22" FillMode="Both" Easing="CubicEaseOut">
                <KeyFrame Cue="0%">
                    <Setter Property="ScaleTransform.ScaleX" Value="0.94" />
                    <Setter Property="ScaleTransform.ScaleY" Value="0.94" />
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="ScaleTransform.ScaleX" Value="1" />
                    <Setter Property="ScaleTransform.ScaleY" Value="1" />
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
            </Animation>
        </Setter>

        <Setter Property="CloseAnimation">
            <Animation Duration="0:0:0.12" FillMode="Both" Easing="CubicEaseIn">
                <KeyFrame Cue="0%">
                    <Setter Property="ScaleTransform.ScaleX" Value="1" />
                    <Setter Property="ScaleTransform.ScaleY" Value="1" />
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="ScaleTransform.ScaleX" Value="0.94" />
                    <Setter Property="ScaleTransform.ScaleY" Value="0.94" />
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
            </Animation>
        </Setter>

        <Setter Property="Template">
            <ControlTemplate>
                <ShadowBorder CornerRadius="{DynamicResource ControlCornerRadius}"
                              BlurRadius="50"
                              ShadowColor="#6E000000"
                              Offset="0 8">
                    <Border Background="{DynamicResource BackgroundColor1}"
                            BorderBrush="{DynamicResource ControlBorderColor}"
                            BorderThickness="{DynamicResource ControlBorderThickness}"
                            CornerRadius="{DynamicResource ControlCornerRadius}"
                            ClipToBounds="True">
                        <Grid RowDefinitions="Auto,Auto,*,Auto">

                            <!-- ── Header: warning icon + exception summary ── -->
                            <Border Grid.Row="0"
                                    Background="{DynamicResource BackgroundColor3}"
                                    BorderBrush="{DynamicResource ControlBorderColor}"
                                    BorderThickness="0 0 0 1"
                                    Padding="20 16">
                                <Grid ColumnDefinitions="Auto,16,*">
                                    <!-- Warning icon badge -->
                                    <Border Grid.Column="0"
                                            Width="44" Height="44"
                                            CornerRadius="{DynamicResource RoundedControlCornerRadius}"
                                            Background="{DynamicResource SystemFillColorCritical}">
                                        <PathIcon Data="{DynamicResource WarningRegular}"
                                                  Width="22" Height="22"
                                                  Foreground="White"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                                    </Border>

                                    <!-- Title + exception message -->
                                    <StackPanel Grid.Column="2" Spacing="4" VerticalAlignment="Center">
                                        <TextBlock FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColor1}">
                                            <Run Text="{TemplateBinding ApplicationName}" />
                                            <Run Text="{TemplateBinding CrashedText}" />
                                        </TextBlock>
                                        <TextBlock Text="{TemplateBinding ExceptionMessage}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextFillColor2}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip.Tip="{TemplateBinding ExceptionMessage}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- ── Tab strip ──────────────────────────────── -->
                            <Border Grid.Row="1"
                                    Background="{DynamicResource BackgroundColor2}"
                                    BorderBrush="{DynamicResource ControlBorderColor}"
                                    BorderThickness="0 0 0 1"
                                    Padding="12 6">
                                <ListBox Name="PART_TabStrip"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ItemContainerTheme="{StaticResource CrashReportTabItemTheme}"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="4" />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                </ListBox>
                            </Border>

                            <!-- ── Tab content ────────────────────────────── -->
                            <Border Grid.Row="2"
                                    MinHeight="260"
                                    MaxHeight="340"
                                    ClipToBounds="True">
                                <Grid>
                                    <!-- General tab -->
                                    <SmoothScrollViewer Name="PART_GeneralTab"
                                                        HorizontalScrollBarVisibility="Disabled"
                                                        VerticalScrollBarVisibility="Auto"
                                                        Padding="20 16">
                                        <StackPanel Spacing="12">
                                            <!-- App info row -->
                                            <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                                                <TextBlock Grid.Row="0" Grid.Column="0"
                                                           Text="{TemplateBinding ApplicationLabel}"
                                                           Foreground="{DynamicResource TextFillColor2}"
                                                           VerticalAlignment="Center" FontSize="12" />
                                                <TextBlock Grid.Row="0" Grid.Column="2"
                                                           Text="{TemplateBinding ApplicationName}"
                                                           FontSize="12"
                                                           VerticalAlignment="Center" />

                                                <TextBlock Grid.Row="1" Grid.Column="0"
                                                           Text="{TemplateBinding VersionLabel}"
                                                           Foreground="{DynamicResource TextFillColor2}"
                                                           VerticalAlignment="Center" FontSize="12" />
                                                <TextBlock Grid.Row="1" Grid.Column="2"
                                                           Text="{TemplateBinding ApplicationVersion}"
                                                           FontSize="12"
                                                           VerticalAlignment="Center" />

                                                <TextBlock Grid.Row="2" Grid.Column="0"
                                                           Text="{TemplateBinding OccurredAtText}"
                                                           Foreground="{DynamicResource TextFillColor2}"
                                                           VerticalAlignment="Center" FontSize="12" />
                                                <TextBlock Grid.Row="2" Grid.Column="2"
                                                           Text="{TemplateBinding OccurredAt}"
                                                           FontSize="12"
                                                           VerticalAlignment="Center" />
                                            </Grid>

                                            <!-- Exception summary (read-only) -->
                                            <Border Background="{DynamicResource BackgroundColor3}"
                                                    BorderBrush="{DynamicResource ControlBorderColor}"
                                                    BorderThickness="{DynamicResource ControlBorderThickness}"
                                                    CornerRadius="{DynamicResource ControlCornerRadius}"
                                                    Padding="10 8">
                                                <SelectableTextBlock Text="{TemplateBinding ExceptionMessage}"
                                                                     FontSize="12"
                                                                     TextWrapping="Wrap"
                                                                     Foreground="{DynamicResource SystemFillColorCritical}" />
                                            </Border>

                                            <!-- User message -->
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{TemplateBinding WhatWereYouDoingText}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TextFillColor2}" />
                                                <TextBox Name="PART_UserMessageBox"
                                                         Height="72"
                                                         AcceptsReturn="True"
                                                         TextWrapping="Wrap"
                                                         PlaceholderText="{TemplateBinding UserMessagePlaceholder}"
                                                         FontSize="12" />
                                            </StackPanel>

                                            <!-- Email -->
                                            <StackPanel Spacing="4">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="{TemplateBinding EmailLabel}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource TextFillColor2}" />
                                                    <TextBlock Name="PART_EmailRequiredBadge"
                                                               Text="(required)"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource SystemFillColorCritical}"
                                                               IsVisible="False" />
                                                </StackPanel>
                                                <TextBox Name="PART_EmailBox"
                                                         PlaceholderText="you@example.com"
                                                         FontSize="12" />
                                                <TextBlock Name="PART_EmailError"
                                                           Text="{TemplateBinding EmailValidationError}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource SystemFillColorCritical}"
                                                           IsVisible="False" />
                                            </StackPanel>
                                        </StackPanel>
                                    </SmoothScrollViewer>

                                    <!-- Exception tab -->
                                    <SmoothScrollViewer Name="PART_ExceptionTab"
                                                        HorizontalScrollBarVisibility="Disabled"
                                                        VerticalScrollBarVisibility="Auto"
                                                        Padding="20 16"
                                                        IsVisible="False">
                                        <StackPanel Spacing="12">
                                            <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto" RowSpacing="10">
                                                <TextBlock Grid.Row="0" Grid.Column="0"
                                                           Text="Type"
                                                           Foreground="{DynamicResource TextFillColor2}"
                                                           VerticalAlignment="Center" FontSize="12" />
                                                <SelectableTextBlock Grid.Row="0" Grid.Column="1"
                                                                     Text="{TemplateBinding ExceptionType}"
                                                                     FontSize="12"
                                                                     FontFamily="Consolas,Menlo,Monaco,monospace"
                                                                     TextTrimming="CharacterEllipsis"
                                                                     VerticalAlignment="Center" />

                                                <TextBlock Grid.Row="1" Grid.Column="0"
                                                           Text="Source"
                                                           Foreground="{DynamicResource TextFillColor2}"
                                                           VerticalAlignment="Center" FontSize="12" />
                                                <SelectableTextBlock Grid.Row="1" Grid.Column="1"
                                                                     Text="{TemplateBinding ExceptionSource}"
                                                                     FontSize="12"
                                                                     TextTrimming="CharacterEllipsis"
                                                                     VerticalAlignment="Center" />
                                            </Grid>

                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{TemplateBinding MessageLabel}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TextFillColor2}" />
                                                <Border Background="{DynamicResource BackgroundColor3}"
                                                        BorderBrush="{DynamicResource ControlBorderColor}"
                                                        BorderThickness="{DynamicResource ControlBorderThickness}"
                                                        CornerRadius="{DynamicResource ControlCornerRadius}"
                                                        Padding="10 8">
                                                    <SelectableTextBlock Text="{TemplateBinding ExceptionMessage}"
                                                                         FontSize="12"
                                                                         TextWrapping="Wrap" />
                                                </Border>
                                            </StackPanel>

                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Stack trace"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TextFillColor2}" />
                                                <Border Background="{DynamicResource BackgroundColor3}"
                                                        BorderBrush="{DynamicResource ControlBorderColor}"
                                                        BorderThickness="{DynamicResource ControlBorderThickness}"
                                                        CornerRadius="{DynamicResource ControlCornerRadius}"
                                                        Padding="10 8"
                                                        MaxHeight="160">
                                                    <SmoothScrollViewer HorizontalScrollBarVisibility="Auto"
                                                                        VerticalScrollBarVisibility="Auto">
                                                        <SelectableTextBlock Text="{TemplateBinding StackTrace}"
                                                                             FontSize="11"
                                                                             FontFamily="Consolas,Menlo,Monaco,monospace"
                                                                             TextWrapping="NoWrap" />
                                                    </SmoothScrollViewer>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>
                                    </SmoothScrollViewer>

                                    <!-- Screenshot tab -->
                                    <Grid Name="PART_ScreenshotTab"
                                          RowDefinitions="Auto,*"
                                          Margin="20 16"
                                          IsVisible="False">
                                        <CheckBox Name="PART_ScreenshotToggle"
                                                  Grid.Row="0"
                                                  Content="{TemplateBinding IncludeScreenshotLabel}"
                                                  IsChecked="{TemplateBinding IncludeScreenshot, Mode=TwoWay}"
                                                  Margin="0 0 0 12" />
                                        <Border Grid.Row="1"
                                                Background="{DynamicResource BackgroundColor3}"
                                                BorderBrush="{DynamicResource ControlBorderColor}"
                                                BorderThickness="{DynamicResource ControlBorderThickness}"
                                                CornerRadius="{DynamicResource ControlCornerRadius}"
                                                ClipToBounds="True">
                                            <Image Source="{TemplateBinding Screenshot}"
                                                   Stretch="Uniform"
                                                   MaxHeight="220" />
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- ── Footer ──────────────────────────────────── -->
                            <Border Grid.Row="3"
                                    Background="{DynamicResource BackgroundColor3}"
                                    BorderBrush="{DynamicResource ControlBorderColor}"
                                    BorderThickness="0 1 0 0"
                                    Padding="16 12">
                                <Grid RowDefinitions="Auto,Auto">

                                    <!-- Status / progress row -->
                                    <Border Grid.Row="0"
                                            Name="PART_StatusRow"
                                            Background="{DynamicResource BackgroundColor2}"
                                            BorderBrush="{DynamicResource ControlBorderColor}"
                                            BorderThickness="{DynamicResource ControlBorderThickness}"
                                            CornerRadius="{DynamicResource ControlCornerRadius}"
                                            Padding="10 7"
                                            Margin="0 0 0 10"
                                            IsVisible="False">
                                        <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
                                            <!-- Text and icons -->
                                            <StackPanel Grid.Row="0"
                                                        Orientation="Horizontal" Spacing="10"
                                                        HorizontalAlignment="Center">
                                                <PathIcon Name="PART_SuccessIcon"
                                                          Data="{DynamicResource CheckmarkRegular}"
                                                          Width="16" Height="16"
                                                          Foreground="{DynamicResource SystemFillColorSuccess}"
                                                          IsVisible="False"
                                                          VerticalAlignment="Center" />
                                                <PathIcon Name="PART_FailureIcon"
                                                          Data="{DynamicResource AlertOutline}"
                                                          Width="16" Height="16"
                                                          Foreground="{DynamicResource SystemFillColorCritical}"
                                                          IsVisible="False"
                                                          VerticalAlignment="Center" />
                                                <TextBlock Text="{TemplateBinding StatusMessage}"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextFillColor1}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                            <!-- Progress bar below -->
                                            <ProgressBar Name="PART_SendingProgress"
                                                         Grid.Row="1"
                                                         IsIndeterminate="True"
                                                         Height="12"
                                                         HorizontalAlignment="Stretch"
                                                         IsVisible="False" />
                                        </Grid>
                                    </Border>

                                    <!-- Action buttons -->
                                    <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto,8,Auto,8,Auto">
                                        <!-- Save button (left) -->
                                        <Button Name="PART_SaveButton"
                                                Grid.Column="0"
                                                Padding="12 6"
                                                FontSize="12">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <PathIcon Data="{DynamicResource DocumentRegular}"
                                                          Width="12" Height="12" />
                                                <TextBlock Text="{TemplateBinding SaveReportLabel}" />
                                            </StackPanel>
                                        </Button>

                                        <!-- Send button -->
                                        <Button Name="PART_SendButton"
                                                Grid.Column="2"
                                                Theme="{DynamicResource AccentButtonTheme}"
                                                Padding="14 6"
                                                FontSize="12">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <PathIcon Data="{DynamicResource ArrowRightRegular}"
                                                          Width="12" Height="12" />
                                                <TextBlock Text="{TemplateBinding SendReportLabel}" />
                                            </StackPanel>
                                        </Button>

                                        <!-- Cancel button -->
                                        <Button Name="PART_CancelButton"
                                                Grid.Column="4"
                                                Padding="12 6"
                                                FontSize="12">
                                            <ContentControl Content="{TemplateBinding CancelLabel}" />
                                        </Button>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </ShadowBorder>
            </ControlTemplate>
        </Setter>

        <!-- ── Tab switching via ListBox selection ────────────────────── -->
        <!-- General tab (index 0 selected or nothing selected) -->
        <Style Selector="^[Tag={Binding GeneralTabLabel, RelativeSource={RelativeSource TemplatedParent}}] /template/ SmoothScrollViewer#PART_GeneralTab">
            <Setter Property="IsVisible" Value="True" />
        </Style>
        <Style Selector="^[Tag={Binding GeneralTabLabel, RelativeSource={RelativeSource TemplatedParent}}] /template/ SmoothScrollViewer#PART_ExceptionTab">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="^[Tag={Binding GeneralTabLabel, RelativeSource={RelativeSource TemplatedParent}}] /template/ Grid#PART_ScreenshotTab">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <Style Selector="^[Tag={Binding ExceptionTabLabel, RelativeSource={RelativeSource TemplatedParent}}] /template/ SmoothScrollViewer#PART_GeneralTab">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="^[Tag={Binding ExceptionTabLabel, RelativeSource={RelativeSource TemplatedParent}}] /template/ SmoothScrollViewer#PART_ExceptionTab">
            <Setter Property="IsVisible" Value="True" />
        </Style>
        <Style Selector="^[Tag={Binding ExceptionTabLabel, RelativeSource={RelativeSource TemplatedParent}}] /template/ Grid#PART_ScreenshotTab">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <Style Selector="^[Tag={Binding ScreenshotTabLabel, RelativeSource={RelativeSource TemplatedParent}}] /template/ SmoothScrollViewer#PART_GeneralTab">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="^[Tag={Binding ScreenshotTabLabel, RelativeSource={RelativeSource TemplatedParent}}] /template/ SmoothScrollViewer#PART_ExceptionTab">
            <Setter Property="IsVisible" Value="False" />
        </Style>
        <Style Selector="^[Tag={Binding ScreenshotTabLabel, RelativeSource={RelativeSource TemplatedParent}}] /template/ Grid#PART_ScreenshotTab">
            <Setter Property="IsVisible" Value="True" />
        </Style>

        <!-- ── Sending state ─────────────────────────────────────────── -->
        <Style Selector="^:sending /template/ Border#PART_StatusRow">
            <Setter Property="IsVisible" Value="True" />
        </Style>
        <Style Selector="^:sending /template/ ProgressBar#PART_SendingProgress">
            <Setter Property="IsVisible" Value="True" />
        </Style>

        <!-- ── Success state ─────────────────────────────────────────── -->
        <Style Selector="^:success /template/ Border#PART_StatusRow">
            <Setter Property="IsVisible" Value="True" />
        </Style>
        <Style Selector="^:success /template/ PathIcon#PART_SuccessIcon">
            <Setter Property="IsVisible" Value="True" />
        </Style>

        <!-- ── Failure state ─────────────────────────────────────────── -->
        <Style Selector="^:failure /template/ Border#PART_StatusRow">
            <Setter Property="IsVisible" Value="True" />
        </Style>
        <Style Selector="^:failure /template/ PathIcon#PART_FailureIcon">
            <Setter Property="IsVisible" Value="True" />
        </Style>

        <!-- ── Email validation ───────────────────────────────────────── -->
        <Style Selector="^:emailRequired /template/ TextBlock#PART_EmailRequiredBadge">
            <Setter Property="IsVisible" Value="True" />
        </Style>
        <Style Selector="^:emailInvalid /template/ TextBlock#PART_EmailError">
            <Setter Property="IsVisible" Value="True" />
        </Style>
        <Style Selector="^:emailInvalid /template/ TextBox#PART_EmailBox">
            <Setter Property="BorderBrush" Value="{DynamicResource SystemFillColorCritical}" />
        </Style>
    </ControlTheme>

</ResourceDictionary>
