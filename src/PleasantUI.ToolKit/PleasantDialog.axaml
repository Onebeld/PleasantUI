<ContentDialog xmlns="https://github.com/avaloniaui"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="420"
               VerticalAlignment="Center"
               HorizontalAlignment="Center"
               Margin="50"
               MinWidth="320"
               MaxWidth="600"
               MinHeight="160"
               x:Class="PleasantUI.ToolKit.PleasantDialog">

    <Grid RowDefinitions="Auto,*,Auto,Auto">

        <!-- ── Header (icon + title + subheader) ──────────────────────── -->
        <Border x:Name="HeaderBorder"
                Grid.Row="0"
                Padding="{DynamicResource PleasantDialogHeaderPadding}">
            <Grid ColumnDefinitions="Auto,*">

                <PathIcon x:Name="HeaderIcon"
                          Grid.Column="0"
                          Width="{DynamicResource PleasantDialogIconSize}"
                          Height="{DynamicResource PleasantDialogIconSize}"
                          Margin="{DynamicResource PleasantDialogIconMargin}"
                          VerticalAlignment="Top"
                          IsVisible="False" />

                <StackPanel Grid.Column="1"
                            Spacing="{DynamicResource PleasantDialogHeaderSpacing}">
                    <TextBlock x:Name="HeaderText"
                               Theme="{DynamicResource SubtitleTextBlockTheme}"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="SubHeaderText"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColor2}"
                               TextWrapping="Wrap"
                               IsVisible="False" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Scrollable body ────────────────────────────────────────── -->
        <SmoothScrollViewer Grid.Row="1"
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="BodyPanel"
                        Margin="{DynamicResource PleasantDialogContentPadding}"
                        Spacing="{DynamicResource PleasantDialogBodySpacing}">

                <TextBlock x:Name="BodyText"
                           TextWrapping="Wrap"
                           IsVisible="False" />

                <!-- Commands: radio buttons, checkboxes, command links -->
                <ItemsControl x:Name="CommandsHost"
                              IsVisible="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="{DynamicResource PleasantDialogCommandSpacing}" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <!-- Extra content slot for arbitrary controls -->
                <ContentPresenter x:Name="ExtraContent"
                                  IsVisible="False" />

            </StackPanel>
        </SmoothScrollViewer>

        <!-- ── Progress bar wrapper ───────────────────────────────────── -->
        <!--
            The wrapper Border animates its Height from 0 to 20 (bar + margins).
            The ProgressBar itself is always in the visual tree so Bounds.Width
            is always a real measured value — this is what makes the indicator
            Width transition animate correctly from the very first SetProgressBarState call.
        -->
        <Border x:Name="ProgressBarWrapper"
                Grid.Row="2"
                Height="0"
                ClipToBounds="True"
                IsHitTestVisible="False">
            <Border.Transitions>
                <Transitions>
                    <DoubleTransition Property="Height" Duration="0:0:0.2" Easing="CubicEaseOut" />
                </Transitions>
            </Border.Transitions>
            <ProgressBar x:Name="ProgressBar"
                         Margin="{DynamicResource PleasantDialogProgressMargin}"
                         Height="8"
                         MinHeight="8"
                         Minimum="0"
                         Maximum="100"
                         Value="0" />
        </Border>

        <!-- ── Footer (expandable) ────────────────────────────────────── -->
        <Border x:Name="FooterBorder"
                Grid.Row="3"
                IsVisible="False"
                BorderBrush="{DynamicResource ControlBorderColor}"
                BorderThickness="0 1 0 0"
                Padding="{DynamicResource PleasantDialogFooterPadding}">
            <StackPanel Spacing="{DynamicResource PleasantDialogFooterSpacing}">
                <Button x:Name="FooterToggleButton"
                        Theme="{DynamicResource PleasantDialogFooterToggleTheme}"
                        IsVisible="False">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon x:Name="FooterChevron"
                                  Data="{DynamicResource ChevronDownRegular}"
                                  Width="12" Height="12"
                                  VerticalAlignment="Center" />
                        <TextBlock x:Name="FooterToggleText"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <ContentPresenter x:Name="FooterContent"
                                  IsVisible="False" />
            </StackPanel>
        </Border>

    </Grid>

    <ContentDialog.BottomPanelContent>
        <UniformGrid x:Name="ButtonsHost" Margin="15 0" Rows="0" />
    </ContentDialog.BottomPanelContent>
</ContentDialog>
