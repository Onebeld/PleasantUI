<ContentDialog xmlns="https://github.com/avaloniaui"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
               VerticalAlignment="Center"
               HorizontalAlignment="Center"
               Margin="50"
               MinWidth="300"
               MinHeight="180"
               x:Class="PleasantUI.ToolKit.MessageBox">
    <Grid RowDefinitions="Auto,*">

        <!-- Danger header — hidden by default, shown for MessageBoxStyle.Danger -->
        <Border x:Name="DangerHeader"
                Grid.Row="0"
                IsVisible="False"
                Background="{DynamicResource DangerColor}"
                Padding="20 14">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <PathIcon Data="{DynamicResource ErrorCircleRegular}"
                          Width="20" Height="20"
                          Foreground="White"
                          VerticalAlignment="Center" />
                <TextBlock x:Name="Title"
                           Theme="{DynamicResource SubtitleTextBlockTheme}"
                           Foreground="White"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <SmoothScrollViewer Grid.Row="1">
            <Grid Margin="20" RowDefinitions="Auto,Auto,Auto">
                <!-- Default title — hidden when danger header is visible -->
                <TextBlock Grid.Row="0"
                           x:Name="DefaultTitle"
                           Theme="{DynamicResource SubtitleTextBlockTheme}"
                           TextWrapping="Wrap" />

                <TextBlock Grid.Row="1"
                           x:Name="Text"
                           Margin="0 10 0 0"
                           TextWrapping="Wrap" />

                <!-- Extra content slot — text, custom controls, etc. Hidden when empty -->
                <ContentPresenter x:Name="ExtraContent"
                                  Grid.Row="2"
                                  Margin="0 10 0 0"
                                  IsVisible="False" />            </Grid>
        </SmoothScrollViewer>
    </Grid>

    <ContentDialog.BottomPanelContent>
        <UniformGrid x:Name="Buttons" Margin="15 0" Rows="0" />
    </ContentDialog.BottomPanelContent>
</ContentDialog>
